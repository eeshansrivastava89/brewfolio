---
import '../../styles/global.css'
import DashboardLayout from 'brewfolio/layouts/DashboardLayout.astro'
import Dashboard from 'brewfolio/components/Dashboard.astro'
import ModalSource from 'brewfolio/components/ModalSource.astro'
import SearchData from 'brewfolio/components/SearchData.astro'
import { getPortfolioData } from '../../lib/portfolio-data'

const { notebooks, projects, searchData } = await getPortfolioData()
const projectById = new Map(projects.map((project) => [project.id, project]))
---

<DashboardLayout meta={{ title: 'Analysis' }}>
	<Dashboard />

	<ModalSource slot="modal-source" path="/analysis" size="medium">
		<section class="analysis-shell">
			<header class="analysis-hero">
				<h1 class="modal-page-title">Published analyses</h1>
				<p class="analysis-hero-intro">A modal-first archive of notebooks, experiments, and recommendations. Each entry can point to a notebook file, GitHub source, or deeper analysis page.</p>
			</header>

			{notebooks.length === 0 ? (
				<div class="analysis-empty">No notebooks published yet.</div>
			) : (
				<div class="analysis-project-grid">
					{notebooks.map((notebook) => {
						const project = projectById.get(notebook.project)
						return (
							<a href={`/analysis/${notebook.id}`} class="analysis-feature-card" data-modal-link>
								<div class="analysis-feature-kicker">{project?.name || notebook.project || 'Analysis'}</div>
								<h2 class="analysis-feature-title">{notebook.title}</h2>
								{notebook.description && <p class="analysis-feature-desc">{notebook.description}</p>}
								<div class="analysis-feature-meta">
									<span>{new Date(notebook.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
									<span class="analysis-feature-cta">Open notebook →</span>
								</div>
							</a>
						)
					})}
				</div>
			)}
		</section>
	</ModalSource>

	<SearchData slot="search-data" data={searchData} />
</DashboardLayout>

<style>
	.analysis-shell {
		display: grid;
		gap: 24px;
	}

	.analysis-hero {
		display: grid;
		gap: 12px;
	}

	.analysis-hero-intro {
		max-width: 46rem;
		color: var(--muted-foreground);
		line-height: 1.65;
	}

	.analysis-empty {
		border: 1px dashed var(--border);
		border-radius: 16px;
		padding: 24px;
		background: var(--card-raised);
		color: var(--muted-foreground);
	}

	.analysis-project-grid {
		display: grid;
		gap: 14px;
	}

	.analysis-feature-card {
		display: block;
		padding: 22px;
		border: 1px solid var(--border);
		border-radius: 18px;
		background: var(--card-raised);
		text-decoration: none;
	}

	.analysis-feature-card:hover {
		text-decoration: none;
	}

	.analysis-feature-kicker {
		margin-bottom: 10px;
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
	}

	.analysis-feature-title {
		margin: 0;
		font-family: var(--font-serif);
		font-size: 1.6rem;
		line-height: 1.1;
		letter-spacing: -0.03em;
	}

	.analysis-feature-desc {
		margin: 12px 0 0;
		color: var(--muted-foreground);
		line-height: 1.65;
	}

	.analysis-feature-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 14px;
		color: var(--muted);
	}

	.analysis-feature-cta {
		color: var(--primary);
		font-weight: 600;
	}

	@media (max-width: 768px) {
		.analysis-feature-card {
			padding: 18px;
		}
	}
</style>
