---
import '../styles/global.css'
import DashboardLayout from 'brewfolio/layouts/DashboardLayout.astro'
import ArticleTOC from 'brewfolio/components/ArticleTOC.astro'
import Dashboard from 'brewfolio/components/Dashboard.astro'
import ModalSource from 'brewfolio/components/ModalSource.astro'
import SearchData from 'brewfolio/components/SearchData.astro'
import { dashboardHeader, getPortfolioData, renderProse } from '../lib/portfolio-data'

const {
	config,
	aboutData,
	timelineData,
	impactData,
	searchData,
} = await getPortfolioData()

const work = (timelineData?.timeline ?? []).filter((item: any) => item.type !== 'education')
const education = (timelineData?.timeline ?? []).filter((item: any) => item.type === 'education')
const impactSections = (impactData?.impact ?? []).filter((section: any) => section.visible)
const currentRole = work[0]
const bioHtml = renderProse(aboutData?.bio)
const thisSiteHtml = renderProse(aboutData?.thisSite)
const siteTitle = config?.siteTitle || ''
const headerConfig = await dashboardHeader(config)
const tocHeadings = [
	{ id: 'this-site', text: 'This Site', level: 2 as const },
	...(impactSections.length > 0 ? [{ id: 'impact', text: 'Recognition & Leadership', level: 2 as const }] : []),
	{ id: 'experience', text: 'Experience', level: 2 as const },
	{ id: 'education', text: 'Education', level: 2 as const },
]
---

<DashboardLayout meta={{ title: 'About', siteTitle }} header={headerConfig}>
	<Dashboard />

	<ModalSource slot="modal-source" path="/about" size="medium">
		<section class="about-masthead">
			<div class="about-masthead-copy">
				<div class="modal-eyebrow">About</div>
				<h1 class="modal-page-title">{siteTitle}</h1>
				{currentRole && (
					<p class="about-role">{currentRole.title}{currentRole.company ? ` · ${currentRole.company}` : ''}</p>
				)}
				<div class="about-prose" set:html={bioHtml} />
			</div>
		</section>

		<section class="about-section" id="this-site">
			<h2 class="about-section-title">This Site</h2>
			<div class="about-prose" set:html={thisSiteHtml} />
		</section>

		{impactSections.length > 0 && (
			<section class="about-section" id="impact">
				<h2 class="about-section-title">Recognition &amp; Leadership</h2>
				<div class="about-impact-grid">
					{impactSections.map((section: any) => (
						<section class="about-impact-card">
							<h3 class="about-impact-card-title">{section.title}</h3>
							<ul class="about-impact-list">
								{section.items.map((item: any) => (
									<li class="about-impact-item">
										{item.link ? (
											<a href={item.link} target="_blank" rel="noopener noreferrer" class="about-impact-link">{item.text}</a>
										) : (
											<span class="about-impact-text">{item.text}</span>
										)}
										{item.meta && <span class="about-impact-meta">{item.meta}</span>}
									</li>
								))}
							</ul>
						</section>
					))}
				</div>
			</section>
		)}

		<section class="about-section" id="experience">
			<h2 class="about-section-title">Experience</h2>
			{work.length > 0 && (
				<div class="about-timeline">
					{work.map((item: any) => (
						<article class="about-timeline-item">
							<div class="about-timeline-rail">
								<div class="about-timeline-dot"></div>
							</div>
							<div class="about-timeline-content">
								<div class="about-timeline-header">
									<h3 class="about-timeline-title">{item.title}</h3>
									{item.company && <span class="about-timeline-company">· {item.company}</span>}
								</div>
								<div class="about-timeline-meta">{item.timespan || 'Dates coming soon'}</div>
								{item.description && <p class="about-timeline-description">{item.description}</p>}
							</div>
						</article>
					))}
				</div>
			)}
		</section>

		<section class="about-section" id="education">
			<h2 class="about-section-title">Education</h2>
			{education.length > 0 && (
				<div class="about-timeline">
					{education.map((item: any) => (
						<article class="about-timeline-item">
							<div class="about-timeline-rail">
								<div class="about-timeline-dot about-timeline-dot-education"></div>
							</div>
							<div class="about-timeline-content">
								<div class="about-timeline-header">
									<h3 class="about-timeline-title">{item.title}</h3>
									{item.company && <span class="about-timeline-company">· {item.company}</span>}
								</div>
								<div class="about-timeline-meta">{item.timespan || 'Dates coming soon'}</div>
								{item.description && <p class="about-timeline-description">{item.description}</p>}
							</div>
						</article>
					))}
				</div>
			)}
		</section>

		<ArticleTOC headings={tocHeadings} topLabel={siteTitle} />
	</ModalSource>

	<SearchData slot="search-data" data={searchData} />
</DashboardLayout>

<style>
	.about-masthead {
		margin-bottom: 36px;
	}

	.about-masthead-copy {
		max-width: 42rem;
	}

	.modal-eyebrow {
		margin-bottom: 10px;
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
	}

	.about-role {
		margin: 10px 0 18px;
		font-size: 1rem;
		font-weight: 600;
		color: var(--muted-foreground);
	}

	.about-section {
		margin-bottom: 32px;
	}

	.about-section-title {
		margin: 0 0 16px;
		font-family: var(--font-serif);
		font-size: 1.7rem;
		letter-spacing: -0.02em;
	}

	.about-prose {
		font-family: var(--font-serif);
		font-size: 1.08rem;
		line-height: 1.75;
		color: var(--foreground);
	}

	.about-prose p {
		margin: 0 0 16px;
	}

	.about-prose :global(a) {
		color: var(--primary);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.about-prose :global(em) {
		font-style: italic;
	}

	.about-prose :global(strong) {
		font-weight: 700;
	}

	.about-timeline {
		display: grid;
		gap: 20px;
	}

	.about-timeline-item {
		display: grid;
		grid-template-columns: 20px minmax(0, 1fr);
		gap: 14px;
		padding-top: 18px;
		border-top: 1px solid var(--border);
	}

	.about-timeline-item:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-timeline-rail {
		padding-top: 4px;
		display: flex;
		justify-content: center;
	}

	.about-timeline-dot {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: var(--primary);
		box-shadow: 0 0 0 4px rgba(var(--primary-rgb), 0.1);
	}

	.about-timeline-dot-education {
		background: var(--muted);
		box-shadow: 0 0 0 4px rgba(var(--primary-rgb), 0.05);
	}

	.about-timeline-content {
		min-width: 0;
	}

	.about-timeline-header {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		align-items: baseline;
	}

	.about-timeline-meta {
		margin-top: 6px;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.about-timeline-title {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 700;
	}

	.about-timeline-company {
		font-weight: 600;
		color: var(--muted-foreground);
	}

	.about-timeline-description {
		margin: 8px 0 0;
		color: var(--muted-foreground);
		line-height: 1.65;
	}

	.about-impact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.about-impact-card {
		padding: 18px;
		border: 1px solid var(--border);
		border-radius: 14px;
		background: var(--card-raised);
	}

	.about-impact-card-title {
		margin: 0 0 12px;
		font-size: 1rem;
		font-weight: 700;
	}

	.about-impact-list {
		margin: 0;
		padding-left: 0;
		list-style: none;
		display: grid;
		gap: 8px;
	}

	.about-impact-item {
		display: grid;
		gap: 2px;
	}

	.about-impact-link {
		color: var(--primary);
		font-weight: 600;
		text-decoration: none;
	}

	.about-impact-link:hover {
		text-decoration: underline;
	}

	.about-impact-text {
		font-weight: 600;
		color: var(--foreground);
	}

	.about-impact-meta {
		display: block;
		margin-top: 2px;
		color: var(--muted);
		font-size: 0.92rem;
	}

	@media (max-width: 768px) {
		.about-impact-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
