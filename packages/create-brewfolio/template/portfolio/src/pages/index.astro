---
import '../styles/global.css'
import DashboardLayout from 'brewfolio/layouts/DashboardLayout.astro'
import Dashboard from 'brewfolio/components/Dashboard.astro'
import ConceptsPane from 'brewfolio/components/ConceptsPane.astro'
import ProjectsPane from 'brewfolio/components/ProjectsPane.astro'
import WritingPane from 'brewfolio/components/WritingPane.astro'
import AnalysisPane from 'brewfolio/components/AnalysisPane.astro'
import GitHubPane from 'brewfolio/components/GitHubPane.astro'
import SearchData from 'brewfolio/components/SearchData.astro'
import { dashboardHeader, getPortfolioData } from '../lib/portfolio-data'

const {
	projects,
	writing,
	notebooks,
	concepts,
	conceptLabelsBySlug,
	config,
	github,
	writingSettings,
	searchData,
} = await getPortfolioData()

const writingWithLabels = writing.map((post) => ({
	...post,
	conceptLabels: conceptLabelsBySlug.get(post.slug) ?? [],
}))

const siteTitle = config?.siteTitle || 'Portfolio'
const headerConfig = dashboardHeader(config)
---

<DashboardLayout meta={{ title: siteTitle, siteTitle }} header={headerConfig}>
	<Dashboard>
		<ConceptsPane conceptsIntro={config?.conceptsIntro} concepts={concepts} />
		<ProjectsPane projects={projects} />
		<WritingPane
			posts={writingWithLabels}
			substackName={writingSettings?.publicationName || ''}
			substackUrl={writingSettings?.subscribeUrl || ''}
		/>
		<AnalysisPane notebooks={notebooks} />
		<GitHubPane data={{}} username={github?.handle || ''} />
	</Dashboard>
	<SearchData slot="search-data" data={searchData} />
</DashboardLayout>
