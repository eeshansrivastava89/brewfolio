---
import '../../styles/global.css'
import DashboardLayout from 'brewfolio/layouts/DashboardLayout.astro'
import Dashboard from 'brewfolio/components/Dashboard.astro'
import ModalSource from 'brewfolio/components/ModalSource.astro'
import ArticleTOC from 'brewfolio/components/ArticleTOC.astro'
import SearchData from 'brewfolio/components/SearchData.astro'
import { extractToc } from 'brewfolio'
import {
	dashboardHeader,
	getPortfolioData,
	modalBreadcrumb,
	substackTitlebar,
	subscribeButton,
} from '../../lib/portfolio-data'

export async function getStaticPaths() {
	const { writing } = await getPortfolioData()

	return writing.map((post) => ({
		params: { slug: post.slug },
	}))
}

const { writing, conceptLabelsBySlug, config, writingSettings, searchData } = await getPortfolioData()
const post = writing.find((entry) => entry.slug === Astro.params.slug)
const siteTitle = config?.siteTitle || ''
const publicationName = writingSettings?.publicationName || ''
const subscribeUrl = writingSettings?.subscribeUrl || ''
const centerHtml = substackTitlebar(publicationName)
const rightHtml = subscribeButton('Subscribe', subscribeUrl)
const leftHtml = modalBreadcrumb('Writing archive', '/writing')
const conceptNames = post ? (conceptLabelsBySlug.get(post.slug) || []).join(' · ') : ''
const bylineName = siteTitle || publicationName || 'Brewfolio'
const bylineInitials = getInitials(bylineName)
const { html: contentWithIds, toc } = post?.contentHtml
	? extractToc(post.contentHtml)
	: { html: '', toc: [] }
const articleCtaLabel = publicationName ? `Read on ${publicationName}` : 'Read article'
const headerConfig = await dashboardHeader(config)

function getInitials(value: string): string {
	const parts = value.trim().split(/\s+/).filter(Boolean)
	if (parts.length === 0) return 'BF'
	if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase()
	return `${parts[0][0]}${parts[1][0]}`.toUpperCase()
}
---

<DashboardLayout meta={{ title: post?.title || 'Writing', siteTitle }} header={headerConfig}>
	<Dashboard />

	<ModalSource
		slot="modal-source"
		path={`/writing/${Astro.params.slug || ''}`}
		leftHtml={leftHtml}
		centerHtml={centerHtml}
		rightHtml={rightHtml}
		size="medium"
	>
		<div class="article-body">
			{!post ? (
				<>
					<div class="modal-eyebrow">Writing</div>
					<h1 class="modal-article-title">Article not found</h1>
					<div class="modal-prose">
						<p>This article slug does not exist in the current CMS data. Go back to the writing archive to choose another entry.</p>
					</div>
				</>
			) : (
				<>
					{conceptNames && <div class="modal-eyebrow">{conceptNames.toUpperCase()}</div>}
					<h1 class="modal-article-title">{post.title}</h1>
					<div class="modal-byline">
						<div class="modal-byline-avatar">{bylineInitials}</div>
						<div class="modal-byline-meta">
							<div class="modal-byline-name">{bylineName}</div>
							<div class="modal-byline-date">{new Date(post.pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</div>
						</div>
					</div>
					{contentWithIds ? (
						<div class="modal-prose" set:html={contentWithIds} />
					) : (
						<div class="modal-prose">
							<p>{post.description}</p>
						</div>
					)}
					<div class="modal-cta-row">
						{post.substack_url && (
							<a href={post.substack_url} target="_blank" rel="noopener noreferrer" class="modal-cta modal-cta-primary">{articleCtaLabel}</a>
						)}
					</div>
				</>
			)}
		</div>
		<ArticleTOC toc={toc} topLabel={post?.title || 'Writing'} />
	</ModalSource>

	<SearchData slot="search-data" data={searchData} />
</DashboardLayout>

<style>
	.modal-prose :global(p) {
		margin-bottom: 18px;
	}

	.modal-prose :global(a) {
		color: var(--primary);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.modal-prose :global(img) {
		width: 100%;
		height: auto;
		border-radius: 12px;
		margin: 28px 0;
	}

	.modal-prose :global(h1),
	.modal-prose :global(h2),
	.modal-prose :global(h3) {
		font-family: var(--font-serif, 'Fraunces', Georgia, serif);
		font-weight: 700;
		color: var(--foreground);
		margin: 32px 0 14px;
		text-wrap: balance;
	}

	.modal-prose :global(h1) {
		font-size: clamp(1.8rem, 3vw, 2.35rem);
		line-height: 1.08;
		letter-spacing: -0.04em;
	}

	.modal-prose :global(blockquote) {
		margin: 24px 0;
		padding-left: 18px;
		border-left: 2px solid var(--border);
		color: var(--muted-foreground);
		font-style: italic;
	}

	.modal-prose :global(ul),
	.modal-prose :global(ol) {
		margin: 20px 0;
		padding-left: 24px;
	}

	.modal-prose :global(li) {
		margin-bottom: 8px;
	}
</style>
