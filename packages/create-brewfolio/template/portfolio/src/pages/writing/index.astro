---
import '../../styles/global.css'
import DashboardLayout from 'brewfolio/layouts/DashboardLayout.astro'
import Dashboard from 'brewfolio/components/Dashboard.astro'
import ModalSource from 'brewfolio/components/ModalSource.astro'
import SearchData from 'brewfolio/components/SearchData.astro'
import { dashboardHeader, getPortfolioData, substackTitlebar, subscribeButton } from '../../lib/portfolio-data'

const { writing, conceptLabelsBySlug, config, writingSettings, searchData } = await getPortfolioData()

const postsByYear = new Map<number, typeof writing>()
for (const post of writing) {
	const year = new Date(post.pubDate).getFullYear()
	if (!postsByYear.has(year)) postsByYear.set(year, [])
	postsByYear.get(year)!.push(post)
}
const years = [...postsByYear.keys()].sort((a, b) => b - a)
const latestPost = writing[0]
const siteTitle = config?.siteTitle || ''
const publicationName = writingSettings?.publicationName || ''
const subscribeUrl = writingSettings?.subscribeUrl || ''
const centerHtml = substackTitlebar(publicationName)
const rightHtml = subscribeButton('Subscribe', subscribeUrl)
const bottomCtaLabel = publicationName ? `Subscribe to ${publicationName}` : 'Subscribe on Substack'
const headerConfig = await dashboardHeader(config)
---

<DashboardLayout meta={{ title: 'Writing', siteTitle }} header={headerConfig}>
	<Dashboard />

	<ModalSource
		slot="modal-source"
		path="/writing"
		centerHtml={centerHtml}
		rightHtml={rightHtml}
		size="medium"
	>
		<section class="writing-archive-shell">
			<header class="writing-archive-hero">
				<h1 class="modal-page-title">Writing archive</h1>
				<p class="writing-archive-intro">Essays on experimentation, local AI, prompting, and product thinking. The archive is organized like a compact editorial index: one featured read, then chronological shelves.</p>
			</header>

			{latestPost && (
				<a href={`/writing/${latestPost.slug}`} class="writing-feature-card" data-modal-link>
					<div class="writing-feature-kicker">Latest</div>
					<h2 class="writing-feature-title">{latestPost.title}</h2>
					<p class="writing-feature-desc">{latestPost.description}</p>
					<div class="writing-feature-meta">
						<span>{new Date(latestPost.pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
						{conceptLabelsBySlug.get(latestPost.slug)?.map((label) => (
							<span class="writing-modal-tag">{label}</span>
						))}
						<span class="writing-feature-cta">Open article →</span>
					</div>
				</a>
			)}

			<div class="writing-year-grid">
				{years.map((year) => (
					<section class="writing-year-card">
						<div class="writing-year-card-header">
							<h3 class="writing-year">{year}</h3>
							<span class="writing-year-count">{postsByYear.get(year)?.length || 0} pieces</span>
						</div>
						<div class="writing-year-list">
							{postsByYear.get(year)?.map((post) => (
								<a href={`/writing/${post.slug}`} class="writing-archive-row" data-modal-link>
									<div class="writing-archive-row-main">
										<div class="writing-modal-title">{post.title}</div>
										<div class="writing-archive-row-desc">{post.description}</div>
									</div>
									<div class="writing-modal-meta">
										<span class="writing-modal-date">{new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
										{conceptLabelsBySlug.get(post.slug)?.map((label) => (
											<span class="writing-modal-tag">{label}</span>
										))}
									</div>
								</a>
							))}
						</div>
					</section>
				))}
			</div>

			{subscribeUrl && (
				<div class="writing-modal-cta">
					<a href={subscribeUrl} target="_blank" rel="noopener noreferrer" class="modal-cta modal-cta-primary">{bottomCtaLabel}</a>
				</div>
			)}
		</section>
	</ModalSource>

	<SearchData slot="search-data" data={searchData} />
</DashboardLayout>

<style>
	.writing-archive-shell {
		display: grid;
		gap: 28px;
	}

	.writing-archive-hero {
		display: grid;
		gap: 12px;
	}

	.writing-archive-intro {
		max-width: 44rem;
		color: var(--muted-foreground);
		line-height: 1.65;
	}

	.writing-feature-card,
	.writing-year-card {
		display: block;
		border: 1px solid var(--border);
		border-radius: 18px;
		background: var(--card-raised);
		padding: 22px;
		text-decoration: none;
	}

	.writing-feature-card:hover,
	.writing-archive-row:hover {
		text-decoration: none;
	}

	.writing-feature-kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 10px;
	}

	.writing-feature-title,
	.writing-year {
		margin: 0;
		font-family: var(--font-serif);
	}

	.writing-feature-title {
		font-size: 2rem;
		line-height: 1.08;
		letter-spacing: -0.03em;
	}

	.writing-feature-desc {
		margin: 14px 0 0;
		color: var(--muted-foreground);
		line-height: 1.65;
	}

	.writing-feature-meta,
	.writing-modal-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 14px;
		font-size: 0.92rem;
		color: var(--muted);
	}

	.writing-feature-cta {
		color: var(--primary);
		font-weight: 600;
	}

	.writing-year-grid {
		display: grid;
		gap: 14px;
	}

	.writing-modal-cta {
		display: flex;
		justify-content: flex-start;
	}

	.writing-year-card-header {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
	}

	.writing-year-count {
		color: var(--muted);
		font-size: 0.92rem;
	}

	.writing-year-list {
		display: grid;
		gap: 2px;
	}

	.writing-archive-row {
		display: flex;
		justify-content: space-between;
		gap: 16px;
		padding: 14px 0;
		border-top: 1px solid var(--border);
	}

	.writing-archive-row:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.writing-modal-title {
		font-weight: 600;
		font-size: 1rem;
	}

	.writing-archive-row-desc {
		margin-top: 6px;
		color: var(--muted-foreground);
		line-height: 1.55;
	}

	.writing-modal-tag {
		font-family: var(--font-mono);
		font-size: 11px;
		background: rgba(var(--primary-rgb), 0.08);
		color: var(--primary);
		padding: 2px 8px;
		border-radius: 999px;
	}

	@media (max-width: 768px) {
		.writing-feature-card,
		.writing-year-card {
			padding: 18px;
		}

		.writing-archive-row {
			flex-direction: column;
		}
	}
</style>
