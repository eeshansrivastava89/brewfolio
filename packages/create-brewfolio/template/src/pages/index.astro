---
import AppLayout from 'brewfolio/layouts/AppLayout.astro'
import type { SectionConfig } from 'brewfolio/lib/types'

const sections: SectionConfig[] = [
  {
    discriminant: 'metrics-grid',
    value: {
      title: 'Welcome',
      metrics: [
        { label: 'Projects', value: '0', delta: 'Add your projects in Keystatic', delta_direction: 'neutral' }
      ]
    }
  }
]
---

<AppLayout
  meta={{ title: 'My Brewfolio Site' }}
  sections={sections}
>
  <p class="text-muted-foreground">Your content goes here.</p>
</AppLayout>
