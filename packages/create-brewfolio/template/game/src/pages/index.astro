---
import '../styles/global.css'
import GameLayout from 'brewfolio/layouts/GameLayout.astro'
import Leaderboard from 'brewfolio/components/Leaderboard.astro'
import Timer from 'brewfolio/components/Timer.astro'
import ScoreDisplay from 'brewfolio/components/ScoreDisplay.astro'
import { resolveHeaderConfig } from 'brewfolio'
import { reader } from '../lib/content'

const [config, gameHome] = await Promise.all([
  reader.singletons.config.read(),
  reader.singletons.gameHome.read(),
])

function parseNumber(value: string | undefined, fallback: number) {
  const parsed = Number(value)
  return Number.isFinite(parsed) ? parsed : fallback
}

const siteTitle = config?.siteTitle?.trim() || ''
const scoreValue = parseNumber(gameHome?.scoreValue, 0)
const previousScoreValue = parseNumber(gameHome?.previousScoreValue, scoreValue)
const timerTotalMs = parseNumber(gameHome?.timerTotalMs, 30000)
const timerVariant =
  gameHome?.timerVariant === 'countup' ? 'countup' : 'countdown'
const headerConfig = await resolveHeaderConfig({
  siteName: siteTitle,
  city: config?.city?.trim() || '',
  country: config?.country?.trim() || '',
})

const entries = (gameHome?.leaderboardEntries ?? []).map((entry) => ({
  rank: parseNumber(entry.rank, 0),
  name: entry.name,
  score: parseNumber(entry.score, 0),
  delta: entry.delta?.trim() ? parseNumber(entry.delta, 0) : undefined,
  isCurrentUser: entry.isCurrentUser,
  variant: entry.variant === 'default' ? undefined : entry.variant,
}))
---

<GameLayout meta={{ title: siteTitle }} siteName={siteTitle} header={headerConfig} showLeaderboard={true}>
  <div class="flex flex-col gap-6 p-4">
    <section class="flex flex-col gap-2">
      <h1 class="font-serif text-2xl font-bold">{gameHome?.roundTitle}</h1>
      <p class="text-muted-foreground text-sm">{gameHome?.subtitle}</p>
    </section>
    <section class="flex gap-6 items-center flex-wrap">
      <ScoreDisplay value={scoreValue} previousValue={previousScoreValue} label={gameHome?.scoreLabel} />
      <Timer variant={timerVariant} totalMs={timerTotalMs} showBar={true} showDigits={true} size="lg" />
    </section>
    <section class="flex flex-col gap-2">
      <h2 class="font-serif text-lg font-bold">{gameHome?.questionTitle}</h2>
      <div class="rounded-lg border border-border bg-card p-6">
        <p class="text-base">{gameHome?.questionPrompt}</p>
        <div class="grid grid-cols-2 gap-2 mt-4">
          {(gameHome?.choices ?? []).map((choice) => (
            <button
              type="button"
              class="rounded-lg border border-border bg-card-raised p-3 hover:border-primary"
            >
              {choice}
            </button>
          ))}
        </div>
      </div>
    </section>
  </div>
  <Leaderboard
    slot="sidebar"
    entries={entries}
    title={gameHome?.leaderboardTitle}
    showDelta={true}
  />
</GameLayout>
