---
import '../styles/global.css'
import AppLayout from 'brewfolio/layouts/AppLayout.astro'
import { getAppData } from '../lib/app-data'

const { siteTitle, headerConfig, sections, githubData, notebookSummaries } = await getAppData()
---

<AppLayout
  meta={{ title: siteTitle }}
  siteName={siteTitle}
  header={headerConfig}
  headerNavItems={[{ label: 'Analysis', href: '/analysis' }]}
  sections={sections}
  notebookEntries={notebookSummaries}
  githubData={githubData}
/>
