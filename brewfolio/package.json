{
	"name": "brewfolio",
	"version": "0.1.15",
	"description": "CMS-driven design system for Astro — tokens, components, layouts, and a Keystatic schema for portfolios, apps, and games.",
	"type": "module",
	"license": "MIT",
	"author": "Eeshan Srivastava",
	"homepage": "https://github.com/eeshansrivastava89/brewfolio#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eeshansrivastava89/brewfolio.git",
		"directory": "brewfolio"
	},
	"bugs": {
		"url": "https://github.com/eeshansrivastava89/brewfolio/issues"
	},
	"keywords": [
		"astro",
		"keystatic",
		"cms",
		"design-system",
		"portfolio",
		"dashboard",
		"tailwind",
		"components"
	],
	"exports": {
		".": "./src/index.ts",
		"./styles/tokens.css": "./src/styles/tokens.css",
		"./keystatic.config": "./src/keystatic.config.ts",
		"./layouts/*": "./src/layouts/*",
		"./components/*": "./src/components/*",
		"./lib/*": "./src/lib/*"
	},
	"files": [
		"src/**/*",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@keystatic/core": ">=0.5.0",
		"@keystatic/astro": ">=5.0.0",
		"astro": ">=5.0.0"
	},
	"dependencies": {
		"marked": "^16.4.1",
		"prismjs": "^1.30.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
