---
/**
 * Mini Clock + Weather Widget
 * Self-updating clock with Open-Meteo weather
 */

interface Props {
  latitude: number
  longitude: number
  city: string
}

const { latitude, longitude, city } = Astro.props

const tickMarks = Array.from({ length: 12 }, (_, index) => index)
---

<div class="flex items-center gap-3">
  <div class="header-clock" translate="no">
    <div class="mini-clock-face" id="miniClockFace" aria-hidden="true">
      {tickMarks.map((tick) => (
        <div
          class:list={['mini-clock-tick', tick % 3 === 0 && 'major']}
          style={`transform: rotate(${tick * 30}deg);`}
        />
      ))}
      <div class="mini-clock-center" />
      <div class="mini-clock-hand hour" id="miniHourHand" />
      <div class="mini-clock-hand minute" id="miniMinuteHand" />
      <div class="mini-clock-hand second" id="miniSecondHand" />
    </div>
    <div class="mini-clock-digital" id="miniDigitalClock">--:--</div>
  </div>

  <div class="header-divider" />

  <div class="header-weather" translate="no">
    <span class="header-weather-icon" id="headerWeatherIcon">⛅</span>
    <span class="header-weather-temp" id="headerWeatherTemp">--°F</span>
    <span class="header-weather-loc">{city}</span>
  </div>
</div>

<script is:inline define:vars={{ latitude, longitude }}>
(function() {
  var SITE_LAT = latitude
  var SITE_LON = longitude

  var hourHand = document.getElementById('miniHourHand')
  var minuteHand = document.getElementById('miniMinuteHand')
  var secondHand = document.getElementById('miniSecondHand')
  var digitalClock = document.getElementById('miniDigitalClock')

  function updateClock() {
    var now = new Date()
    var s = now.getSeconds()
    var m = now.getMinutes()
    var h = now.getHours() % 12
    var ms = now.getMilliseconds()

    var secondAngle = (s + ms / 1000) * 6
    var minuteAngle = (m + s / 60) * 6
    var hourAngle = (h + m / 60) * 30

    if (hourHand) hourHand.style.transform = 'rotate(' + hourAngle + 'deg)'
    if (minuteHand) minuteHand.style.transform = 'rotate(' + minuteAngle + 'deg)'
    if (secondHand) secondHand.style.transform = 'rotate(' + secondAngle + 'deg)'

    if (digitalClock) {
      var h12 = h || 12
      var minutes = String(m).padStart(2, '0')
      var ampm = h >= 12 ? 'PM' : 'AM'
      digitalClock.textContent = h12 + ':' + minutes + ' ' + ampm
    }

    requestAnimationFrame(updateClock)
  }

  updateClock()

  var weatherIcon = document.getElementById('headerWeatherIcon')
  var weatherTemp = document.getElementById('headerWeatherTemp')
  var weatherLastFetch = 0

  function weatherEmoji(code) {
    if (code >= 0 && code <= 1) return '☀️'
    if (code >= 2 && code <= 3) return '⛅'
    if (code >= 45 && code <= 48) return '☁️'
    if (code >= 51 && code <= 67) return '🌧️'
    if (code >= 71 && code <= 77) return '❄️'
    if (code >= 80 && code <= 82) return '🌧️'
    if (code >= 95) return '⛈️'
    return '⛅'
  }

  function fetchWeather() {
    var now = Date.now()
    if (now - weatherLastFetch < 30 * 60 * 1000) return
    weatherLastFetch = now

    var url = 'https://api.open-meteo.com/v1/forecast?latitude=' + SITE_LAT + '&longitude=' + SITE_LON + '&current=temperature_2m,weather_code&temperature_unit=fahrenheit&timezone=auto'

    fetch(url)
      .then(function(response) { return response.json() })
      .then(function(data) {
        var current = data && data.current
        if (!current) return
        if (weatherTemp && typeof current.temperature_2m === 'number') {
          weatherTemp.textContent = Math.round(current.temperature_2m) + '\u00B0F'
        }
        if (weatherIcon) weatherIcon.textContent = weatherEmoji(current.weather_code)
      })
      .catch(function() {})
  }

  fetchWeather()
  setInterval(fetchWeather, 30 * 60 * 1000)
})()
</script>

<style>
  .header-clock {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mini-clock-face {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: var(--card);
    position: relative;
    flex-shrink: 0;
  }

  .mini-clock-tick {
    position: absolute;
    top: 2px;
    left: 50%;
    width: 1px;
    height: 4px;
    margin-left: -0.5px;
    background: var(--muted);
    transform-origin: 50% 12px;
    opacity: 0.7;
  }

  .mini-clock-tick.major {
    height: 5px;
    background: var(--foreground);
    opacity: 0.9;
  }

  .mini-clock-center {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    background: var(--foreground);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
  }

  .mini-clock-hand {
    position: absolute;
    bottom: 50%;
    left: 50%;
    transform-origin: 50% 100%;
    border-radius: 1px;
  }

  .mini-clock-hand.hour {
    width: 2px;
    height: 8px;
    background: var(--foreground);
    margin-left: -1px;
    z-index: 3;
  }

  .mini-clock-hand.minute {
    width: 1.5px;
    height: 10px;
    background: var(--foreground);
    margin-left: -0.75px;
    z-index: 2;
  }

  .mini-clock-hand.second {
    width: 1px;
    height: 11px;
    background: var(--primary);
    margin-left: -0.5px;
    z-index: 1;
  }

  .mini-clock-digital,
  .header-weather-temp {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 600;
    color: var(--foreground);
    white-space: nowrap;
  }

  .header-divider {
    width: 1px;
    height: 18px;
    background: var(--border);
  }

  .header-weather {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .header-weather-icon {
    font-size: 14px;
    line-height: 1;
  }

  .header-weather-loc {
    font-size: 10px;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .mini-clock-face {
      display: none;
    }

    .mini-clock-digital,
    .header-weather-temp {
      font-size: 12px;
    }
  }
</style>
