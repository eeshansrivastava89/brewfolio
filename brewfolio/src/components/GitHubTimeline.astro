---
import type { GitHubData } from '../lib/types'

interface Props {
	title?: string
	githubData: GitHubData
	profileUrl?: string
	profileHandle?: string
	class?: string
}

const {
	title = 'GitHub',
	githubData,
	profileUrl,
	profileHandle,
	class: className = '',
} = Astro.props

const WEEKS_TO_SHOW = 26
const weeks = githubData.weeks.slice(-WEEKS_TO_SHOW)

const sixMonthContributions = weeks
	.flatMap((w) => w.contributionDays)
	.reduce((sum, d) => sum + (d.contributionCount || 0), 0)

const activity = githubData.recentActivity
const totals = githubData.activityTotals

const commitRows = activity.filter((a) => a.category === 'commit').slice(0, 6)
const issueRows  = activity.filter((a) => a.category === 'issue').slice(0, 4)
const prRows     = activity.filter((a) => a.category === 'pr').slice(0, 4)

const allDays = githubData.weeks.flatMap((w) => w.contributionDays)
const maxDayCount = Math.max(...allDays.map((d) => d.contributionCount), 1)
function getContribLevel(count: number): number {
	if (count === 0) return 0
	if (count <= maxDayCount * 0.25) return 1
	if (count <= maxDayCount * 0.5) return 2
	if (count <= maxDayCount * 0.75) return 3
	return 4
}

function contribLevelClass(level: number): string {
	return level === 0 ? '' : `l${level}`
}

const COMMIT_ICON = '<path d="M10.5 7.75a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm1.43.75a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.75a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"/>'
const ISSUE_ICON  = '<path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z"/>'
const PR_ICON     = '<path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/>'
---

<section class={`brewfolio-gh-timeline flex flex-col gap-4 ${className}`} aria-label={title}>
	<header class="flex items-center gap-2.5">
		<h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground m-0">{title}</h2>
		{profileUrl && (
			<a
				href={profileUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-1.5 font-mono text-xs text-muted-foreground no-underline hover:text-primary transition-colors"
			>
				<svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12" aria-hidden="true">
					<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
				</svg>
				{profileHandle && <span>{profileHandle}</span>}
			</a>
		)}
	</header>

	<div class="bg-card border border-border rounded-xl overflow-hidden flex flex-col">
		{weeks.length > 0 && (
			<div class="p-4 pb-3 flex flex-col gap-2 border-b border-border">
				<span class="font-mono text-xs text-muted-foreground">
					{sixMonthContributions.toLocaleString()} contributions in the last 6 months
				</span>
				<div class="grid gap-0.5" style={`grid-template-columns: repeat(${weeks.length}, minmax(0, 1fr));`}>
					{weeks.map((week) => (
						<div class="grid gap-0.5" style="grid-template-rows: repeat(7, minmax(0, 1fr));">
							{week.contributionDays.map((day) => (
								<div
									class:list={['w-full aspect-square rounded-sm border border-input', contribLevelClass(getContribLevel(day.contributionCount))]}
									title={`${day.date}: ${day.contributionCount}`}
								></div>
							))}
						</div>
					))}
				</div>
			</div>
		)}

		<div class="grid grid-cols-2">
			<div class="flex flex-col p-3.5 gap-0.5">
				<div class="flex items-center gap-1.5 text-xs font-semibold text-muted-foreground pb-2 mb-1 border-b border-input">
					<svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13" set:html={COMMIT_ICON} />
					<span>{totals.commits.toLocaleString()} commits</span>
				</div>
				{commitRows.length === 0 ? (
					<span class="text-xs text-muted-foreground italic px-1.5 py-1.5">No commits yet</span>
				) : commitRows.map((row) => (
					<a
						href={row.url}
						target="_blank"
						rel="noopener noreferrer"
						class="grid grid-cols-[110px_1fr] gap-2.5 px-1.5 py-1 rounded-md text-xs no-underline text-inherit hover:bg-card-raised transition-colors"
					>
						<span class="text-primary font-medium whitespace-nowrap overflow-hidden text-ellipsis">{row.repo}</span>
						<span class="font-mono text-xs text-muted-foreground whitespace-nowrap overflow-hidden text-ellipsis">{row.message}</span>
					</a>
				))}
			</div>

			<div class="flex flex-col p-3.5 gap-0.5 border-l border-border">
				<div class="flex items-center gap-1.5 text-xs font-semibold text-muted-foreground pb-2 mb-1 border-b border-input">
					<svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13" set:html={ISSUE_ICON} />
					<span>{totals.issues} issues · {totals.prs} PRs</span>
				</div>
				{[...issueRows, ...prRows].length === 0 ? (
					<span class="text-xs text-muted-foreground italic px-1.5 py-1.5">No recent activity</span>
				) : [...issueRows, ...prRows].map((row) => (
					<a
						href={row.url}
						target="_blank"
						rel="noopener noreferrer"
						class="grid grid-cols-[110px_1fr] gap-2.5 px-1.5 py-1 rounded-md text-xs no-underline text-inherit hover:bg-card-raised transition-colors"
					>
						<span class="text-primary font-medium whitespace-nowrap overflow-hidden text-ellipsis">{row.repo}</span>
						<span class="font-mono text-xs text-muted-foreground whitespace-nowrap overflow-hidden text-ellipsis">{row.message}</span>
					</a>
				))}
			</div>
		</div>
	</div>
</section>

{/* CSS kept for: contribution heat level rgba var injection, grid-template-columns var, border-l on activity col */}
<style>
	.l1 { background: rgba(var(--primary-rgb), 0.35); border-color: transparent !important; }
	.l2 { background: rgba(var(--primary-rgb), 0.55); border-color: transparent !important; }
	.l3 { background: rgba(var(--primary-rgb), 0.75); border-color: transparent !important; }
	.l4 { background: var(--primary); border-color: transparent !important; }

	@media (max-width: 640px) {
		.grid-cols-2 { grid-template-columns: 1fr; }
		.border-l { border-left: none; }
		.border-b { border-bottom: 1px solid var(--border); }
	}
</style>