---
/**
 * StatsGrid — Display metric cards in a responsive auto-fit grid, or a side-by-side
 * comparison of two variants (A vs B) with proportional bar charts.
 *
 * USE CASES
 *   • Dashboard stat cards — show key metrics with value, label, optional delta, and trend arrow
 *   • A/B comparison view — compare two models/experiments across multiple dimensions
 *
 * SOURCE APP: howiprompt (stat cards), ab-simulator (comparison grid)
 * DATSASCIENCEAPPS: Inline stat cards in dashboard CSS
 *
 * PROPS (stats mode)
 *   stats[]        — array of { value, label, delta?, deltaType?, trend? }
 *                    trend: 'up' | 'down' | 'flat'  deltaType: 'up' | 'down' | 'neutral'
 *
 * PROPS (comparison mode)
 *   comparison[]   — array of { label, aValue, bValue, aLabel?, bLabel? }
 *                    Values are compared proportionally; larger value wins its row.
 *
 * EXAMPLES
 *   <StatsGrid stats={[{ value: 94.2, label: 'Avg F1', delta: '+2.1', deltaType: 'up', trend: 'up' }]} />
 *   <StatsGrid comparison={[{ label: 'Latency', aValue: 340, bValue: 520, aLabel: 'GPT-4', bLabel: 'Claude' }]} />
 */

interface StatItem {
	value: string | number
	label: string
	delta?: string
	deltaType?: 'up' | 'down' | 'neutral'
	trend?: 'up' | 'down' | 'flat'
}

interface ComparisonStat {
	label: string
	aValue: string | number
	bValue: string | number
	aLabel?: string
	bLabel?: string
}

interface Props {
	stats?: StatItem[]
	comparison?: ComparisonStat[]
	class?: string
}

const {
	stats = [],
	comparison = [],
	class: className = '',
} = Astro.props
---

{(stats.length > 0 || comparison.length > 0) && (
<div class={`brewfolio-statsgrid flex flex-col gap-4 ${className}`}>
	{stats.length > 0 && (
		<div class="stats-grid">
			{stats.map((stat) => (
				<div class="stat-card">
					<div class="flex items-center gap-1.5">
						<span class="font-mono text-[26px] font-bold tracking-[-0.03em] text-foreground leading-none">
							{stat.value}
						</span>
						{stat.trend && (
							<span class={`trend-icon trend-icon--${stat.trend}`} aria-label={`Trend: ${stat.trend}`}>
								{stat.trend === 'up' && (
									<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
										<path d="M6 2L10 6L8.5 6L8.5 10L3.5 10L3.5 6L2 6L6 2Z" fill="currentColor"/>
									</svg>
								)}
								{stat.trend === 'down' && (
									<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
										<path d="M6 10L2 6L3.5 6L3.5 2L8.5 2L8.5 6L10 6L6 10Z" fill="currentColor"/>
									</svg>
								)}
								{stat.trend === 'flat' && (
									<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
										<path d="M2 6L6 3L10 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
								)}
							</span>
						)}
					</div>
					<span class="text-[12px] text-muted-foreground uppercase tracking-[0.06em] font-medium">
						{stat.label}
					</span>
					{stat.delta && (
						<span class={`text-[11px] font-mono font-medium delta-text--${stat.deltaType || 'neutral'}`}>
							{stat.delta}
						</span>
					)}
				</div>
			))}
		</div>
	)}

	{comparison.length > 0 && (
		<div class="comparison-grid">
			<div class="comparison-header comparison-col-a">
				<span class="text-[11px] font-bold uppercase tracking-[0.08em] text-muted-foreground">
					{comparison[0]?.aLabel || 'A'}
				</span>
			</div>
			<div class="comparison-header comparison-col-b">
				<span class="text-[11px] font-bold uppercase tracking-[0.08em] text-muted-foreground">
					{comparison[0]?.bLabel || 'B'}
				</span>
			</div>
			<div class="comparison-header comparison-col-label" aria-hidden="true"></div>

			{comparison.map((stat) => {
				const aNum = typeof stat.aValue === 'number' ? stat.aValue : parseFloat(String(stat.aValue)) || 0
				const bNum = typeof stat.bValue === 'number' ? stat.bValue : parseFloat(String(stat.bValue)) || 0
				const max = Math.max(aNum, bNum)
				const aPct = max > 0 ? (aNum / max) * 100 : 50
				const bPct = max > 0 ? (bNum / max) * 100 : 50
				const aWinner = aNum > bNum
				const bWinner = bNum > aNum
				return (
					<>
						<div class={`comparison-cell comparison-col-a ${aWinner ? 'winner' : ''}`}>
							<div class="h-1.5 bg-input rounded-full overflow-hidden">
								<div class="comparison-bar h-full rounded-full" style={`width: ${aPct}%`}></div>
							</div>
							<span class="font-mono text-[14px] font-semibold text-foreground text-center">
								{stat.aValue}
							</span>
						</div>
						<div class={`comparison-cell comparison-col-b ${bWinner ? 'winner' : ''}`}>
							<div class="h-1.5 bg-input rounded-full overflow-hidden">
								<div class="comparison-bar h-full rounded-full" style={`width: ${bPct}%`}></div>
							</div>
							<span class="font-mono text-[14px] font-semibold text-foreground text-center">
								{stat.bValue}
							</span>
						</div>
						<div class="comparison-cell comparison-col-label">
							<span class="text-[12px] text-muted-foreground leading-snug">{stat.label}</span>
						</div>
					</>
				)
			})}
		</div>
	)}
</div>
)}

{(stats.length === 0 && comparison.length === 0) && (
	<p class="text-sm text-muted-foreground italic">No stats available.</p>
)}

{/*
STYLING NOTES (brewfolio convention: CSS for animations, scrollbars, contextual state
selectors, pseudo-elements; Tailwind for layout/spacing/typography)
- Animations: @keyframes liveGlow, runningPulse — CSS only
- Status-state selectors: [data-status='running'] — CSS only
- Scrollbar styling — CSS only
- Comparison bar winners/losers opacity: contextual selector — CSS only
- All layout, spacing, typography, colors — via Tailwind vars and inline styles
*/}
<style>
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 10px;
	}

	.stat-card {
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 16px 18px 14px;
	}

	.trend-icon {
		display: inline-flex;
		align-items: center;
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}
	.trend-icon--up { color: var(--green); }
	.trend-icon--down { color: var(--red); }
	.trend-icon--flat { color: var(--muted-foreground); }

	.delta-text--up { color: var(--green); }
	.delta-text--down { color: var(--red); }
	.delta-text--neutral { color: var(--muted-foreground); }

	/* --- Comparison Grid --- */
	.comparison-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 120px;
		gap: 8px 12px;
		align-items: center;
	}

	.comparison-header {
		display: flex;
		align-items: center;
		justify-content: center;
		padding-bottom: 6px;
		border-bottom: 1px solid var(--input);
	}

	.comparison-cell {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
	}

	.comparison-bar {
		background: var(--primary);
		transition: width 0.4s ease;
		min-width: 2px;
	}

	.comparison-cell.winner .comparison-bar { opacity: 1; }
	.comparison-cell:not(.winner) .comparison-bar { opacity: 0.45; }
</style>
