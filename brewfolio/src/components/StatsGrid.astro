---
interface StatItem {
	value: string | number
	label: string
	delta?: string
	deltaType?: 'up' | 'down' | 'neutral'
	trend?: 'up' | 'down' | 'flat'
}

interface ComparisonStat {
	label: string
	aValue: string | number
	bValue: string | number
	aLabel?: string
	bLabel?: string
}

interface Props {
	stats?: StatItem[]
	comparison?: ComparisonStat[]
	class?: string
}

const {
	stats = [],
	comparison = [],
	class: className = '',
} = Astro.props
---

{(stats.length > 0 || comparison.length > 0) && (
<div class={`brewfolio-statsgrid ${className}`}>
	{stats.length > 0 && (
		<div class="stats-grid">
			{stats.map((stat) => (
				<div class="stat-card">
					<div class="stat-value">
						{stat.value}
						{stat.trend && (
							<span class={`stat-trend stat-trend--${stat.trend}`} aria-label={`Trend: ${stat.trend}`}>
								{stat.trend === 'up' && (
									<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
										<path d="M6 2L10 6L8.5 6L8.5 10L3.5 10L3.5 6L2 6L6 2Z" fill="currentColor"/>
									</svg>
								)}
								{stat.trend === 'down' && (
									<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
										<path d="M6 10L2 6L3.5 6L3.5 2L8.5 2L8.5 6L10 6L6 10Z" fill="currentColor"/>
									</svg>
								)}
								{stat.trend === 'flat' && (
									<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
										<path d="M2 6L6 3L10 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
								)}
							</span>
						)}
					</div>
					<div class="stat-label">{stat.label}</div>
					{stat.delta && (
						<div class={`stat-delta stat-delta--${stat.deltaType || 'neutral'}`}>
							{stat.delta}
						</div>
					)}
				</div>
			))}
		</div>
	)}

	{comparison.length > 0 && (
		<div class="comparison-grid">
			<div class="comparison-header comparison-col-a">
				<span class="comparison-variant-label">{comparison[0]?.aLabel || 'A'}</span>
			</div>
			<div class="comparison-header comparison-col-b">
				<span class="comparison-variant-label">{comparison[0]?.bLabel || 'B'}</span>
			</div>
			<div class="comparison-header comparison-col-label" aria-hidden="true"></div>

			{comparison.map((stat) => {
				const aNum = typeof stat.aValue === 'number' ? stat.aValue : parseFloat(String(stat.aValue)) || 0
				const bNum = typeof stat.bValue === 'number' ? stat.bValue : parseFloat(String(stat.bValue)) || 0
				const max = Math.max(aNum, bNum)
				const aPct = max > 0 ? (aNum / max) * 100 : 50
				const bPct = max > 0 ? (bNum / max) * 100 : 50
				const aWinner = aNum > bNum
				const bWinner = bNum > aNum
				return (
					<>
						<div class={`comparison-cell comparison-col-a ${aWinner ? 'winner' : ''}`}>
							<div class="comparison-bar-wrap">
								<div class="comparison-bar" style={`width: ${aPct}%`}></div>
							</div>
							<span class="comparison-value">{stat.aValue}</span>
						</div>
						<div class={`comparison-cell comparison-col-b ${bWinner ? 'winner' : ''}`}>
							<div class="comparison-bar-wrap">
								<div class="comparison-bar" style={`width: ${bPct}%`}></div>
							</div>
							<span class="comparison-value">{stat.bValue}</span>
						</div>
						<div class="comparison-cell comparison-col-label">
							<span class="comparison-label">{stat.label}</span>
						</div>
					</>
				)
			})}
		</div>
	)}
</div>
)}

{(stats.length === 0 && comparison.length === 0) && (
	<p class="text-sm text-muted-foreground italic">No stats available.</p>
)}

<style>
	.brewfolio-statsgrid {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* --- Stats Grid --- */
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 10px;
	}

	.stat-card {
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 16px 18px 14px;
		box-shadow: var(--shadow);
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-value {
		font-family: var(--font-mono, 'JetBrains Mono', monospace);
		font-size: 26px;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--foreground);
		line-height: 1;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.stat-trend {
		display: inline-flex;
		align-items: center;
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	.stat-trend--up { color: var(--green); }
	.stat-trend--down { color: var(--red); }
	.stat-trend--flat { color: var(--muted-foreground); }

	.stat-label {
		font-size: 12px;
		color: var(--muted-foreground);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-weight: 500;
	}

	.stat-delta {
		font-family: var(--font-mono, monospace);
		font-size: 11px;
		font-weight: 500;
		margin-top: 2px;
	}

	.stat-delta--up { color: var(--green); }
	.stat-delta--down { color: var(--red); }
	.stat-delta--neutral { color: var(--muted-foreground); }

	/* --- Comparison Grid --- */
	.comparison-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 120px;
		gap: 8px 12px;
		align-items: center;
	}

	.comparison-header {
		display: flex;
		align-items: center;
		justify-content: center;
		padding-bottom: 6px;
		border-bottom: 1px solid var(--input);
	}

	.comparison-variant-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted-foreground);
	}

	.comparison-cell {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
	}

	.comparison-bar-wrap {
		height: 6px;
		background: var(--input);
		border-radius: 999px;
		overflow: hidden;
	}

	.comparison-bar {
		height: 100%;
		background: var(--primary);
		border-radius: 999px;
		transition: width 0.4s ease;
		min-width: 2px;
	}

	.comparison-cell.winner .comparison-bar {
		background: var(--primary);
	}

	.comparison-cell:not(.winner) .comparison-bar {
		opacity: 0.5;
	}

	.comparison-value {
		font-family: var(--font-mono, monospace);
		font-size: 14px;
		font-weight: 600;
		color: var(--foreground);
		text-align: center;
	}

	.comparison-col-label {
		display: flex;
		align-items: center;
	}

	.comparison-label {
		font-size: 12px;
		color: var(--muted-foreground);
		line-height: 1.3;
	}
</style>
