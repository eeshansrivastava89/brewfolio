---
type Status = 'live' | 'running' | 'completed' | 'failed' | 'idle' | 'paused'

interface Props {
	status: Status
	showLabel?: boolean
	size?: 'sm' | 'md' | 'lg'
	class?: string
}

const {
	status,
	showLabel = false,
	size = 'md',
	class: className = '',
} = Astro.props

const sizeMap = {
	sm: { dot: '10px', label: '11px' },
	md: { dot: '12px', label: '13px' },
	lg: { dot: '16px', label: '15px' },
}

const labelMap: Record<Status, string> = {
	live: 'Live',
	running: 'Running',
	completed: 'Completed',
	failed: 'Failed',
	idle: 'Idle',
	paused: 'Paused',
}

const dotSize = sizeMap[size].dot
const labelSize = sizeMap[size].label
---

<div class={`brewfolio-status ${className}`} data-status={status}>
	<span
		class="status-dot"
		style={`width: ${dotSize}; height: ${dotSize};`}
		aria-hidden="true"
	></span>
	{showLabel && (
		<span class="status-label" style={`font-size: ${labelSize}`}>
			{labelMap[status]}
		</span>
	)}
	<span class="sr-only">{labelMap[status]}</span>
</div>

<style>
	.brewfolio-status {
		display: inline-flex;
		align-items: center;
		gap: 7px;
	}

	.status-dot {
		border-radius: 50%;
		display: inline-block;
		flex-shrink: 0;
		position: relative;
	}

	/* Live — solid green with subtle glow */
	[data-status='live'] .status-dot {
		background: var(--green);
		box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.4);
		animation: liveGlow 2s ease-out infinite;
	}

	/* Running — blue with pulse ring */
	[data-status='running'] .status-dot {
		background: var(--blue);
		animation: runningPulse 1.4s ease-out infinite;
	}

	/* Completed — emerald with check */
	[data-status='completed'] .status-dot {
		background: var(--green);
	}

	/* Failed — red */
	[data-status='failed'] .status-dot {
		background: var(--red);
	}

	/* Idle — gray */
	[data-status='idle'] .status-dot {
		background: var(--muted-foreground);
		opacity: 0.5;
	}

	/* Paused — amber */
	[data-status='paused'] .status-dot {
		background: #eab308;
	}

	.status-label {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-weight: 500;
		color: var(--muted-foreground);
		letter-spacing: 0.01em;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	@keyframes liveGlow {
		0% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.4); }
		50% { box-shadow: 0 0 0 4px rgba(22, 163, 74, 0); }
		100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0); }
	}

	@keyframes runningPulse {
		0% {
			box-shadow: 0 0 0 0 rgba(26, 91, 219, 0.5);
			transform: scale(1);
		}
		70% {
			box-shadow: 0 0 0 8px rgba(26, 91, 219, 0);
			transform: scale(0.95);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(26, 91, 219, 0);
			transform: scale(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.status-dot {
			animation: none !important;
		}
	}
</style>
