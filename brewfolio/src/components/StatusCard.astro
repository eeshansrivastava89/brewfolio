---
/**
 * StatusCard — Animated status indicator dot with optional label.
 * Shows a colored dot that reflects a process state, with pulse/glow animations
 * for active states (live, running) and static fill for terminal states.
 *
 * USE CASES
 *   • Inline status badge anywhere a live/Paused/Completed/Failed state needs display
 *   • Task queue processors, experiment runs, background workers, connection states
 *   • Works well inside table rows, card headers, or list items
 *
 * SOURCE APP: llm-bench (inline status dot with pulse)
 *
 * PROPS
 *   status     — 'live' | 'running' | 'completed' | 'failed' | 'idle' | 'paused'
 *   showLabel  — whether to render the text label next to the dot (default false)
 *   size       — 'sm' | 'md' | 'lg' (controls dot diameter, default 'md')
 *
 * ANIMATIONS (CSS only — Tailwind can't express keyframe-based pulse/glow)
 *   live:  subtle radial glow pulse every 2s
 *   running: expanding ring pulse every 1.4s
 *   All animations disabled via prefers-reduced-motion
 */

type Status = 'live' | 'running' | 'completed' | 'failed' | 'idle' | 'paused'

interface Props {
	status: Status
	showLabel?: boolean
	size?: 'sm' | 'md' | 'lg'
	class?: string
}

const {
	status,
	showLabel = false,
	size = 'md',
	class: className = '',
} = Astro.props

const sizeMap = {
	sm: { dot: '10px', label: '11px' },
	md: { dot: '12px', label: '13px' },
	lg: { dot: '16px', label: '15px' },
}

const labelMap: Record<Status, string> = {
	live: 'Live',
	running: 'Running',
	completed: 'Completed',
	failed: 'Failed',
	idle: 'Idle',
	paused: 'Paused',
}

const dotSize = sizeMap[size].dot
const labelSize = sizeMap[size].label
---

<div class={`brewfolio-status-card inline-flex items-center gap-[7px] ${className}`} data-status={status}>
	<span
		class="status-dot rounded-full inline-block shrink-0"
		style={`width: ${dotSize}; height: ${dotSize};`}
		aria-hidden="true"
	></span>
	{showLabel && (
		<span class="text-muted-foreground font-medium" style={`font-size: ${labelSize}`}>
			{labelMap[status]}
		</span>
	)}
	<span class="sr-only">{labelMap[status]}</span>
</div>

<style>
	/* Live — solid green with radial glow pulse */
	[data-status='live'] .status-dot {
		background: var(--green);
		animation: liveGlow 2s ease-out infinite;
	}

	/* Running — blue with expanding ring pulse */
	[data-status='running'] .status-dot {
		background: var(--blue);
		animation: runningPulse 1.4s ease-out infinite;
	}

	/* Completed — solid green, no animation */
	[data-status='completed'] .status-dot {
		background: var(--green);
	}

	/* Failed — red */
	[data-status='failed'] .status-dot {
		background: var(--red);
	}

	/* Idle — dim gray */
	[data-status='idle'] .status-dot {
		background: var(--muted-foreground);
		opacity: 0.5;
	}

	/* Paused — amber */
	[data-status='paused'] .status-dot {
		background: #eab308;
	}

	.sr-only {
		position: absolute;
		width: 1px; height: 1px;
		padding: 0; margin: -1px;
		overflow: hidden;
		clip: rect(0,0,0,0);
		white-space: nowrap;
		border-width: 0;
	}

	@keyframes liveGlow {
		0%   { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.4); }
		50%  { box-shadow: 0 0 0 4px rgba(22, 163, 74, 0); }
		100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0); }
	}

	@keyframes runningPulse {
		0%   { box-shadow: 0 0 0 0 rgba(26, 91, 219, 0.5); transform: scale(1); }
		70%  { box-shadow: 0 0 0 8px rgba(26, 91, 219, 0); transform: scale(0.95); }
		100% { box-shadow: 0 0 0 0 rgba(26, 91, 219, 0); transform: scale(1); }
	}

	@media (prefers-reduced-motion: reduce) {
		.status-dot { animation: none !important; }
	}
</style>
