---
/**
 * Article Table of Contents - Sticky floating TOC with scroll spy
 */

interface Entry {
	id: string
	text: string
	level: 2 | 3
}

interface Props {
	headings?: Entry[]
	toc?: Entry[]
	topLabel?: string
	minEntries?: number
}

const {
	headings = [],
	toc = [],
	topLabel = 'Overview',
	minEntries = 3,
} = Astro.props

const entries = headings.length > 0 ? headings : toc
const visible = entries.length >= minEntries
---

{visible && (
	<aside class="article-toc" aria-label="Table of contents">
		<div class="article-toc-label">On this page</div>
		<nav class="article-toc-nav" id="tocNav">
			{topLabel && (
				<a
					href="#top"
					class="article-toc-link article-toc-top"
					data-toc-link="__top"
				>
					{topLabel}
				</a>
			)}
			{entries.map((entry) => (
				<a
					href={`#${entry.id}`}
					class:list={['article-toc-link', `article-toc-level-${entry.level}`]}
					data-toc-link={entry.id}
				>
					{entry.text}
				</a>
			))}
		</nav>
	</aside>
)}

<style is:global>
	.article-toc {
		display: none;
		font-family: var(--font-sans, 'DM Sans', system-ui, sans-serif);
		font-size: 13px;
		line-height: 1.45;
	}

	.article-toc-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin-bottom: 12px;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--input);
	}

	.article-toc-nav {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.article-toc-link {
		display: block;
		padding: 5px 8px;
		color: var(--muted-foreground);
		text-decoration: none;
		border-radius: 4px;
		transition: color 0.15s ease;
		text-wrap: balance;
	}

	.article-toc-link:hover {
		color: var(--foreground);
		text-decoration: none;
	}

	.article-toc-link.active {
		color: var(--primary);
		font-weight: 600;
	}

	.article-toc-level-3 {
		padding-left: 20px;
		font-size: 12px;
	}

	.article-toc-top {
		font-family: var(--font-serif, 'Fraunces', Georgia, serif);
		font-size: 13px;
		font-weight: 600;
		color: var(--foreground);
		margin-bottom: 10px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--input);
		text-wrap: balance;
	}

	.article-toc-top:hover,
	.article-toc-top.active {
		color: var(--primary);
	}

	@media (min-width: 1180px) {
		.article-toc {
			display: block;
			position: fixed;
			top: 140px;
			right: 32px;
			width: 188px;
			max-height: calc(100vh - 180px);
			overflow-y: auto;
			overscroll-behavior: contain;
			padding-right: 8px;
			scrollbar-width: thin;
			z-index: 201;
		}
	}
</style>
