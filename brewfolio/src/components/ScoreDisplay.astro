---
/**
 * ScoreDisplay — Large animated numeric score with optional label and delta indicator.
 * Renders the score in a prominent monospace display with an up/down delta badge.
 *
 * USE CASES
 *   • Game score display — quizzard (total score, final score)
 *   • Leaderboard point totals
 *   • Metric dashboards (revenue, users, conversions)
 *
 * SOURCE APP: quizzard (score display, trophy animation for top 3)
 * THIS COMPONENT: Static server-rendered display; no JS needed for base rendering
 *
 * PROPS
 *   value           — the score value
 *   label           — optional label below the score (e.g. "Total Points")
 *   previousValue   — if set, shows a delta badge (value - previousValue)
 *   formatAs        — 'number' | 'currency' | 'percent' (default 'number')
 *
 * STYLING NOTES
 *   Delta badge positive/negative colors — CSS only
 *   All layout/spacing/typography — via Tailwind
 */

interface Props {
	value: number
	label?: string
	previousValue?: number
	formatAs?: 'number' | 'currency' | 'percent'
	class?: string
}

const {
	value,
	label,
	previousValue,
	formatAs = 'number',
	class: className = '',
} = Astro.props

function formatValue(val: number, format: string) {
	switch (format) {
		case 'currency':
			return val.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 })
		case 'percent':
			return `${(val * 100).toFixed(1)}%`
		default:
			return val.toLocaleString()
	}
}

const displayValue = formatValue(value, formatAs)
---

<div class={`brewfolio-scoredisplay inline-flex flex-col gap-1 ${className}`}>
	<div class="flex flex-col gap-0.5">
		<span class="score-value font-mono text-[36px] font-bold tracking-[-0.03em]
			text-foreground font-variant-numeric tabular-nums leading-none">
			{displayValue}
		</span>
		{label && (
			<span class="text-[12px] text-muted-foreground uppercase tracking-[0.07em] font-medium">
				{label}
			</span>
		)}
	</div>
	{previousValue !== undefined && previousValue !== value && (
		<div aria-live="polite"
			aria-label={`Changed from ${formatValue(previousValue, formatAs)}`}>
			<span class={`delta-badge inline-flex items-center gap-1 font-mono text-[12px] font-semibold
				px-2 py-1 rounded-full
				${value > previousValue
					? 'text-green bg-green/10'
					: 'text-red bg-red/10'}`}>
				{value > previousValue ? (
					<svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
						<path d="M5 2L8 6H2L5 2Z"/>
					</svg>
				) : (
					<svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
						<path d="M5 8L2 4H8L5 8Z"/>
					</svg>
				)}
				{formatValue(Math.abs(value - previousValue), formatAs)}
			</span>
		</div>
	)}
</div>
