---
interface Props {
	value: number
	label?: string
	previousValue?: number
	formatAs?: 'number' | 'currency' | 'percent'
	class?: string
}

const {
	value,
	label,
	previousValue,
	formatAs = 'number',
	class: className = '',
} = Astro.props

const scoreId = `score-${Math.random().toString(36).slice(2, 8)}`

function formatValue(val: number, format: string) {
	switch (format) {
		case 'currency':
			return val.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 })
		case 'percent':
			return `${(val * 100).toFixed(1)}%`
		default:
			return val.toLocaleString()
	}
}

const displayValue = formatValue(value, formatAs)
---

<div class={`brewfolio-scoredisplay ${className}`} id={scoreId} data-format={formatAs}>
	<div class="score-inner">
		<span class="score-value" aria-live="polite">{displayValue}</span>
		{label && <span class="score-label">{label}</span>}
	</div>
	{previousValue !== undefined && previousValue !== value && (
		<div class="score-delta" aria-live="polite" aria-label={`Changed from ${formatValue(previousValue, formatAs)}`}>
			<span class={`delta-badge ${value > previousValue ? 'positive' : 'negative'}`}>
				{value > previousValue ? (
					<svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true"><path d="M5 2L8 6H2L5 2Z"/></svg>
				) : (
					<svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true"><path d="M5 8L2 4H8L5 8Z"/></svg>
				)}
				{formatValue(Math.abs(value - previousValue), format)}
			</span>
		</div>
	)}
</div>

<style>
	.brewfolio-scoredisplay {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 4px;
	}

	.score-inner {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.score-value {
		font-family: var(--font-mono, 'JetBrains Mono', monospace);
		font-size: 36px;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--foreground);
		font-variant-numeric: tabular-nums;
		line-height: 1;
		transition: color 0.3s ease;
	}

	.score-label {
		font-size: 12px;
		color: var(--muted-foreground);
		text-transform: uppercase;
		letter-spacing: 0.07em;
		font-weight: 500;
	}

	.score-delta {
		display: flex;
		align-items: center;
	}

	.delta-badge {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-family: var(--font-mono, monospace);
		font-size: 12px;
		font-weight: 600;
		padding: 3px 8px;
		border-radius: 999px;
	}

	.delta-badge.positive {
		color: var(--green);
		background: rgba(22, 163, 74, 0.1);
	}

	.delta-badge.negative {
		color: var(--red);
		background: rgba(210, 15, 57, 0.1);
	}
</style>
