---
interface Props {
	conceptsIntro?: string
	concepts: Array<{
		slug: string
		name: string
		description?: string
		projectCount?: number
		writingCount?: number
		notebookCount?: number
	}>
}

const {
	conceptsIntro,
	concepts = []
} = Astro.props
---

<section class="pane pane-concepts" data-pane="concepts" aria-label="Concepts">
	<div class="pane-header">
		<h2>Concepts</h2>
	</div>
	{conceptsIntro && <p class="concepts-intro">{conceptsIntro}</p>}
	<div class="pane-body">
		{concepts.map((concept) => (
			<button
				class="concept-row"
				type="button"
				data-concept={concept.slug}
				data-concept-filter={concept.slug}
				aria-pressed="false"
				aria-label={`Filter by ${concept.name}`}
			>
				<div class="concept-info">
					<div class="concept-name">{concept.name}</div>
					{concept.description && <div class="concept-desc">{concept.description}</div>}
				</div>
			</button>
		))}
	</div>
</section>

<style>
	.concepts-intro {
		margin: 0;
		padding: 12px 14px;
		font-family: var(--font-serif);
		font-size: 14px;
		line-height: 1.5;
		color: var(--foreground);
		background: rgba(var(--primary-rgb), 0.08);
		border-bottom: 1px solid var(--input);
	}

	.concept-row {
		display: flex;
		align-items: center;
		gap: 12px;
		width: 100%;
		padding: 9px 14px;
		cursor: pointer;
		transition: background-color 0.15s ease, border-color 0.15s ease;
		border: 0;
		border-left: 3px solid transparent;
		background: transparent;
		text-align: left;
		touch-action: manipulation;
	}

	.concept-row:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: -2px;
	}

	.concept-row:hover {
		background: var(--card-raised);
	}

	.concept-row.active {
		background: var(--accent);
		border-left-color: var(--primary);
	}

	.concept-info {
		flex: 1;
		min-width: 0;
	}

	.concept-name {
		font-weight: 700;
		font-size: 15px;
		line-height: 1.25;
		color: var(--foreground);
	}

	.concept-desc {
		font-size: 12px;
		color: var(--muted-foreground);
		margin-top: 1px;
		line-height: 1.35;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
</style>