---
/**
 * FilterBar — Horizontal row of toggleable filter chip buttons.
 * Supports single-select (radio-style) or multi-select (checkbox-style) modes.
 * Fires a `filter-change` CustomEvent on the element with `{ value, active }`.
 *
 * USE CASES
 *   • Dashboard concept filters — filter projects/writing/notebooks by topic
 *   • Table column filters
 *   • Any horizontal filter group (status, category, date range)
 *
 * SOURCE APP: sidequests (stats-bar.tsx signal filters)
 * CONCEPTS: ConceptsPane, ProjectsPane — filter project tiles by concept slug
 *
 * PROPS
 *   options[]  — { value, label, count?, icon? }
 *   active     — comma-separated active values (for multi) or single value (for single)
 *   multi      — enable multi-select mode (default false = single select)
 *
 * STYLING NOTES
 *   aria-pressed state (JS-driven, not Tailwind-controlled) — CSS only
 *   .active chip border + bg + text color — CSS only (attribute selector, not class toggle)
 *   Hover on non-active — via Tailwind
 *   Chip pill appearance (border-radius: 999px) — Tailwind
 */

interface FilterOption {
	value: string
	label: string
	count?: number
	icon?: string
}

interface Props {
	options: FilterOption[]
	active?: string
	multi?: boolean
	class?: string
}

const {
	options,
	active = '',
	multi = false,
	class: className = '',
} = Astro.props

const activeFilters = active ? active.split(',').filter(Boolean) : []
---

<div class={`brewfolio-filterbar flex flex-wrap gap-2 ${className}`}
	data-multi={multi ? 'true' : 'false'}
	role="group"
	aria-label="Filter options">
	{options.map((opt) => {
		const isActive = multi
			? activeFilters.includes(opt.value)
			: active === opt.value

		return (
			<button
				class={`filter-chip inline-flex items-center gap-1.5 px-3.5 py-1.5
					border border-border rounded-full bg-card text-[13px] font-medium
					cursor-pointer transition-all duration-150 leading-tight
					${isActive ? 'active' : ''}`}
				data-value={opt.value}
				aria-pressed={isActive ? 'true' : 'false'}
				type="button"
			>
				{opt.icon && <span class="text-[13px]" aria-hidden="true">{opt.icon}</span>}
				<span class="font-normal">{opt.label}</span>
				{opt.count !== undefined && (
					<span class="font-mono text-[11px] opacity-70">{opt.count}</span>
				)}
			</button>
		)
	})}
</div>

<script is:inline>
(function () {
	function initFilterBar(el) {
		const multi = el.getAttribute('data-multi') === 'true'
		const chips = el.querySelectorAll('.filter-chip')

		function getActive() {
			return Array.from(chips)
				.filter((c) => c.getAttribute('aria-pressed') === 'true')
				.map((c) => c.getAttribute('data-value'))
				.filter(Boolean)
		}

		function update() {
			const active = getActive()
			const val = multi ? active.join(',') : (active[0] || '')
			el.dispatchEvent(new CustomEvent('filter-change', { detail: { value: val, active }, bubbles: true }))
		}

		chips.forEach((chip) => {
			chip.addEventListener('click', () => {
				const val = chip.getAttribute('data-value') || ''
				if (multi) {
					const pressed = chip.getAttribute('aria-pressed') === 'true'
					chip.setAttribute('aria-pressed', pressed ? 'false' : 'true')
				} else {
					chips.forEach((c) => c.setAttribute('aria-pressed', 'false'))
					chip.setAttribute('aria-pressed', 'true')
				}
				update()
			})
		})
	}

	document.querySelectorAll('.brewfolio-filterbar').forEach(initFilterBar)
})()
</script>

<style>
	.filter-chip:hover:not(.active) {
		border-color: var(--muted-foreground);
		color: var(--foreground);
	}

	/* Active state via aria-pressed (JS-driven, not class-based Tailwind) */
	.filter-chip[aria-pressed='true'] {
		border-color: var(--primary);
		background: var(--primary);
		color: var(--primary-foreground);
		box-shadow: var(--shadow);
	}
</style>
