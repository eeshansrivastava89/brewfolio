---
const START_YEAR = 2025
const currentYear = new Date().getFullYear()
const yearDisplay = currentYear > START_YEAR ? `${START_YEAR}–${currentYear}` : `${START_YEAR}`
---

<footer class="flex items-center justify-center gap-4 px-6 py-3 border-t border-border text-muted text-[11px] font-sans flex-shrink-0">
	<span>© {yearDisplay} Personal project · MIT License</span>
</footer>