---
/**
 * Impact Shelf - Sequential sections with left-border accent
 * Filter by `visible: true`
 */

interface ImpactItem {
  text: string
  link?: string
  meta?: string
}

interface ImpactSection {
  title: string
  icon: string
  visible: boolean
  items: ImpactItem[]
}

interface Props {
  sections: ImpactSection[]
}

const { sections } = Astro.props
const visibleSections = sections.filter(section => section.visible)

function getIconName(icon: string): string {
  if (icon.startsWith('lucide:') || icon.startsWith('mdi:') || icon.includes(':')) {
    return icon
  }
  return `lucide:${icon}`
}
---

{visibleSections.length > 0 && (
  <div class="space-y-8">
    {visibleSections.map((section) => (
      <div class="relative pl-4 border-l border-primary/30 hover:border-primary/60 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg" aria-hidden="true">{section.icon}</span>
          <h3 class="text-lg font-semibold text-foreground">{section.title}</h3>
        </div>
        <ul class="space-y-2 text-sm text-muted-foreground">
          {section.items.map((item) => (
            <li class="flex items-start gap-2">
              <span class="text-primary/50 mt-0.5 shrink-0">•</span>
              <div class="flex-1 min-w-0">
                {item.link ? (
                  <a
                    href={item.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-foreground transition-colors inline-flex items-center gap-1.5"
                  >
                    {item.text}
                    {item.meta && (
                      <span class="text-xs text-muted-foreground/60 font-mono">{item.meta}</span>
                    )}
                  </a>
                ) : (
                  <span>{item.text}</span>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
)}

{visibleSections.length === 0 && (
  <p class="text-sm text-muted-foreground italic">Coming soon.</p>
)}
