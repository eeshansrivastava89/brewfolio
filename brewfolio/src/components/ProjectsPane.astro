---
import type { Project, ProjectGitHubData } from '../lib/types'

interface Props {
	projects: Project[]
	projectGitHubData?: Map<string, ProjectGitHubData | null>
}

const { projects, projectGitHubData } = Astro.props

function getStatusDot(status: string): string {
	return status === 'live' ? 'live' : 'dev'
}

function getStatusLabel(status: string): string {
	if (status === 'live') return 'Live'
	if (status === 'in-progress') return 'In Dev'
	if (status === 'coming-soon') return 'Coming Soon'
	return status
}
---

<section class="pane pane-projects" data-pane="projects" aria-label="Projects">
	<div class="pane-header">
		<h2>Projects</h2>
	</div>
	<div class="pane-body">
		{projects.length === 0 && (
			<p class="bf-empty-hint" style="padding: 16px 14px;">
				Add projects in <strong>Keystatic → Projects</strong>. Each project gets a tile
				here plus a drawer with extra context when detail fields are filled in.
			</p>
		)}
		<div class="project-tiles">
			{projects.map((project) => (
				<article
					class="project-tile"
					data-project-id={project.id}
					data-project-json={JSON.stringify(project)}
					data-github-json={JSON.stringify(projectGitHubData?.get(project.id) ?? null)}
					role="button"
					tabindex="0"
					aria-label={`Open ${project.name} details`}
				>
					<div class="project-tile-name">{project.name}</div>
					<div class="project-tile-desc">{project.shortDescription || project.description}</div>
					{project.tags && project.tags.length > 0 && (
						<div class="project-tile-tags">
							{project.tags.slice(0, 4).map((tag) => (
								<span class="tech-tag">{tag.name}</span>
							))}
						</div>
					)}
					<div class="project-tile-footer">
						<span class="project-tile-status">
							<span class={`status-dot ${getStatusDot(project.status)}`}></span>
							{getStatusLabel(project.status)}
						</span>
						<div class="project-tile-actions">
							{project.url && (
								<a href={project.url} target="_blank" rel="noopener noreferrer" class="project-cta">
									Try it
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="project-cta-icon" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
								</a>
							)}
							{project.repo && (
								<a href={project.repo} target="_blank" rel="noopener noreferrer" class="project-cta-secondary">
									<svg viewBox="0 0 24 24" fill="currentColor" class="project-cta-icon" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
									Source
								</a>
							)}
						</div>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.project-tiles {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 10px;
		padding: 10px;
	}

	.project-tile {
		background: var(--card-raised);
		border: 1px solid var(--input);
		border-radius: var(--radius-sm);
		padding: 14px;
		display: flex;
		flex-direction: column;
		gap: 6px;
		position: relative;
		min-height: 184px;
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			opacity 0.3s ease,
			background-color 0.2s ease;
	}

	.project-tile:focus-visible {
		outline: 2px solid var(--ring);
		outline-offset: 2px;
	}

	.project-tile:hover {
		border-color: rgba(var(--primary-rgb), 0.35);
		box-shadow: var(--shadow-hover);
	}

	.project-tile.highlighted {
		background: var(--accent);
		border-color: var(--primary);
	}

	.project-tile.dimmed {
		opacity: 0.25;
	}

	.project-tile-name {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: 17px;
		letter-spacing: -0.02em;
		color: var(--foreground);
		margin-bottom: 2px;
	}

	.project-tile-desc {
		font-size: 13px;
		color: var(--muted-foreground);
		line-height: 1.45;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin-bottom: 6px;
	}

	.project-tile-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		margin-top: auto;
	}

	.project-tile-status {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted-foreground);
	}

	.status-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		display: inline-block;
	}

	.status-dot.live {
		background: var(--green);
	}

	.status-dot.dev {
		background: #eab308;
	}

	:global([data-theme='dark']) .status-dot.dev {
		background: #fbbf24;
	}

	.project-tile-actions {
		display: flex;
		gap: 6px;
		align-items: center;
	}

	.project-cta,
	.project-cta-secondary {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-family: var(--font-sans);
		font-size: 12px;
		text-decoration: none;
		padding: 5px 12px;
		border-radius: 999px;
		line-height: 1.2;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.project-cta-icon {
		width: 11px;
		height: 11px;
		flex-shrink: 0;
	}

	.project-cta {
		font-weight: 600;
		color: var(--primary);
		border: 1px solid rgba(var(--primary-rgb), 0.28);
		background: rgba(var(--primary-rgb), 0.04);
	}

	.project-cta:hover {
		background: var(--primary);
		border-color: var(--primary);
		color: var(--card);
		text-decoration: none;
	}

	.project-cta-secondary {
		font-weight: 500;
		color: var(--muted-foreground);
		border: 1px solid var(--border);
	}

	.project-cta-secondary:hover {
		border-color: var(--primary);
		color: var(--primary);
		text-decoration: none;
	}

	.project-tile-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		margin-top: 2px;
	}

	.tech-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		background: rgba(var(--primary-rgb), 0.08);
		color: var(--primary);
		padding: 2px 8px;
		border-radius: 20px;
		font-weight: 500;
	}

	@media (max-width: 768px) {
		.project-tiles {
			grid-template-columns: 1fr;
		}
	}
</style>

<script is:inline>
	(function () {
		function esc(value) {
			return value
				? String(value)
						.replace(/&/g, '&amp;')
						.replace(/</g, '&lt;')
						.replace(/>/g, '&gt;')
						.replace(/"/g, '&quot;')
				: ''
		}

		function statusLabel(status) {
			return status === 'live'
				? 'Live'
				: status === 'in-progress'
					? 'In Dev'
					: status === 'coming-soon'
						? 'Coming Soon'
						: status
		}

		function statusColor(status) {
			return status === 'live' ? 'var(--green)' : '#eab308'
		}

		function fmtDate(iso) {
			if (!iso) return ''
			var date = new Date(iso)
			var now = new Date()
			var time = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })
			if (date.toDateString() === now.toDateString()) return 'today ' + time
			return (
				date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) +
				' ' +
				time
			)
		}

		var ghIcon =
			'<svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>'
		var extIcon =
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="11" height="11"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>'
		function sectionHeader(label, right) {
			return (
				'<div class="bf-pdr-section-header"><span>' + label + '</span>' + (right || '') + '</div>'
			)
		}

		function timelineMarkup(commits, page, pageSize) {
			var start = page * pageSize
			var pageItems = commits.slice(start, start + pageSize)
			var rows = pageItems
				.map(function (commit) {
					return (
						'<a href="' +
						esc(commit.url) +
						'" target="_blank" rel="noopener noreferrer" class="bf-pdr-commit">' +
						'<span class="bf-pdr-commit-label">git</span>' +
						'<span class="bf-pdr-commit-msg">' +
						esc(commit.message) +
						'</span>' +
						'<span class="bf-pdr-commit-date">' +
						fmtDate(commit.date) +
						'</span>' +
						'</a>'
					)
				})
				.join('')

			return rows || '<div class="bf-pdr-info-msg">No activity yet.</div>'
		}

		function timelinePaginationMarkup(totalPages, currentPage) {
			if (totalPages <= 1) return ''
			var buttons = []
			buttons.push(
				'<button type="button" class="bf-pdr-page-btn" data-bf-pdr-page="' +
					(currentPage - 1) +
					'"' +
					(currentPage === 0 ? ' disabled' : '') +
					'>&lt;</button>',
			)
			for (var i = 0; i < totalPages; i++) {
				buttons.push(
					'<button type="button" class="bf-pdr-page-btn' +
						(i === currentPage ? ' is-active' : '') +
						'" data-bf-pdr-page="' +
						i +
						'">' +
						(i + 1) +
						'</button>',
				)
			}
			buttons.push(
				'<button type="button" class="bf-pdr-page-btn" data-bf-pdr-page="' +
					(currentPage + 1) +
					'"' +
					(currentPage === totalPages - 1 ? ' disabled' : '') +
					'>&gt;</button>',
			)
			return buttons.join('')
		}

		function buildDrawerContent(project, githubData) {
			var root = document.createElement('div')
			var commits = githubData && githubData.recentCommits ? githubData.recentCommits : []
			var pageSize = 8
			var totalPages = Math.max(1, Math.ceil(commits.length / pageSize))
			var primaryOverview = project.overview || project.description || ''
			var relatedWritingItems = Array.isArray(project.relatedWritingItems)
				? project.relatedWritingItems
				: []

			var actionLinks = []
			if (project.url) {
				actionLinks.push(
					'<a href="' +
						esc(project.url) +
						'" target="_blank" rel="noopener noreferrer" class="bf-pdr-cta">Try it ' +
						extIcon +
						'</a>',
				)
			}
			if (project.repo) {
				actionLinks.push(
					'<a href="' +
						esc(project.repo) +
						'" target="_blank" rel="noopener noreferrer" class="bf-pdr-cta-sec">' +
						ghIcon +
						' GitHub</a>',
				)
			}
			if (project.featuredNotebook) {
				actionLinks.push(
					'<a href="/analysis/' +
						esc(project.featuredNotebook) +
						'" class="bf-pdr-cta-sec" data-modal-link data-close-drawer="true">Open analysis</a>',
				)
			}

			var tagMarkup = ''
			if (project.tags) {
				tagMarkup = project.tags
					.map(function (tag) {
						return '<span class="bf-pdr-tag">' + esc(tag.name) + '</span>'
					})
					.join('')
			}

			var relatedLinks = []
			if (project.featuredNotebook) {
				relatedLinks.push(
					'<a href="/analysis/' +
						esc(project.featuredNotebook) +
						'" class="bf-pdr-related-link" data-modal-link data-close-drawer="true">' +
						esc(project.featuredNotebookTitle || 'Featured notebook') +
						'</a>',
				)
			}
			relatedWritingItems.slice(0, 3).forEach(function (item) {
				relatedLinks.push(
					'<a href="' +
						esc(item.href) +
						'" class="bf-pdr-related-link" data-modal-link data-close-drawer="true">' +
						esc(item.title) +
						'</a>',
				)
			})

			root.className = 'bf-pdr-root'
			root.innerHTML =
				'<div class="bf-pdr-meta"><span class="bf-pdr-status"><span class="bf-pdr-dot" style="background:' +
				statusColor(project.status) +
				'"></span>' +
				esc(statusLabel(project.status)) +
				'</span>' +
				tagMarkup +
				'</div>' +
				(actionLinks.length
					? '<div class="bf-pdr-links">' + actionLinks.join('') + '</div>'
					: '') +
				'<section class="bf-pdr-section">' +
				sectionHeader(
					'GITHUB',
					githubData
						? '<span class="bf-pdr-sync">Synced ' + fmtDate(githubData.syncedAt) + '</span>'
						: '',
				) +
				'<div class="bf-pdr-card">' +
				(githubData
					? '<div class="bf-pdr-stats">' +
						'<div class="bf-pdr-stat"><div class="bf-pdr-stat-val">' +
						githubData.openIssues +
						'</div><div class="bf-pdr-stat-label">Issues</div></div>' +
						'<div class="bf-pdr-stat"><div class="bf-pdr-stat-val">' +
						githubData.openPRs +
						'</div><div class="bf-pdr-stat-label">PRs</div></div>' +
						'<div class="bf-pdr-stat"><div class="bf-pdr-stat-val bf-pdr-stat-badge ' +
						esc(githubData.visibility) +
						'">' +
						esc(githubData.visibility.charAt(0).toUpperCase() + githubData.visibility.slice(1)) +
						'</div><div class="bf-pdr-stat-label">Visibility</div></div>' +
						'</div>'
					: '<div class="bf-pdr-info-msg">' +
						(project.repo
							? 'Could not load GitHub data.'
							: 'Add a GitHub repository URL in Keystatic to unlock repo stats and the project timeline.') +
						'</div>') +
				'</div></section>' +
				'<section class="bf-pdr-section">' +
				sectionHeader('PROJECT OVERVIEW') +
				'<div class="bf-pdr-card">' +
				(primaryOverview
					? '<div class="bf-pdr-copy-block"><div class="bf-pdr-subsection-label">What is it?</div><p class="bf-pdr-body">' +
						esc(primaryOverview) +
						'</p></div>'
					: '') +
				(project.architecture
					? '<div class="bf-pdr-copy-block"><div class="bf-pdr-subsection-label">Architecture / Tech Stack</div><p class="bf-pdr-body">' +
						esc(project.architecture) +
						'</p></div>'
					: '') +
				(project.nextActions
					? '<div class="bf-pdr-copy-block"><div class="bf-pdr-subsection-label">Next actions / Updates</div><p class="bf-pdr-body">' +
						esc(project.nextActions) +
						'</p></div>'
					: '') +
				(relatedLinks.length
					? '<div class="bf-pdr-copy-block"><div class="bf-pdr-subsection-label">Linked work</div><div class="bf-pdr-related-links">' +
						relatedLinks.join('') +
						'</div></div>'
					: '') +
				(!primaryOverview && !project.architecture && !project.nextActions && !relatedLinks.length
					? '<div class="bf-pdr-info-msg">No drawer copy configured yet. Fill in the overview fields in Keystatic.</div>'
					: '') +
				'</div></section>' +
				'<section class="bf-pdr-section">' +
				sectionHeader('TIMELINE') +
				'<div class="bf-pdr-card">' +
				'<div class="bf-pdr-timeline" data-bf-pdr-timeline-body></div>' +
				'<div class="bf-pdr-pagination" data-bf-pdr-timeline-pagination></div>' +
				'</div></section>'

			root.addEventListener('click', function (event) {
				var closeLink = event.target.closest('[data-close-drawer]')
				if (closeLink && window.__bfCloseDrawer) {
					window.__bfCloseDrawer()
				}

				var pageBtn = event.target.closest('[data-bf-pdr-page]')
				if (!pageBtn) return
				var nextPage = Number(pageBtn.getAttribute('data-bf-pdr-page'))
				if (!Number.isFinite(nextPage)) return
				renderTimeline(nextPage)
			})

			var timelineBody = root.querySelector('[data-bf-pdr-timeline-body]')
			var timelinePagination = root.querySelector('[data-bf-pdr-timeline-pagination]')

			function renderTimeline(page) {
				var safePage = Math.min(Math.max(page, 0), totalPages - 1)
				if (timelineBody) {
					timelineBody.innerHTML = timelineMarkup(commits, safePage, pageSize)
				}
				if (timelinePagination) {
					timelinePagination.innerHTML = timelinePaginationMarkup(totalPages, safePage)
					timelinePagination.hidden = totalPages <= 1
				}
			}

			renderTimeline(0)
			return root
		}

		function initTiles() {
			document.querySelectorAll('[data-project-json]').forEach(function (tile) {
				function open(event) {
					if (event && event.target && event.target.closest('a')) return
					var project
					var githubData
					try {
						project = JSON.parse(tile.getAttribute('data-project-json'))
					} catch {
						return
					}
					try {
						githubData = JSON.parse(tile.getAttribute('data-github-json'))
					} catch {
						githubData = null
					}
					if (window.__bfOpenDrawer) {
						window.__bfOpenDrawer(project.name, buildDrawerContent(project, githubData))
					}
				}

				if (tile.dataset.drawerBound === 'true') return
				tile.dataset.drawerBound = 'true'
				tile.addEventListener('click', open)
				tile.addEventListener('keydown', function (event) {
					if (event.key === 'Enter' || event.key === ' ') {
						event.preventDefault()
						open(null)
					}
				})
			})
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initTiles)
		} else {
			initTiles()
		}
		document.addEventListener('astro:page-load', initTiles)
	})()
</script>

<style is:global>
	.bf-pdr-root {
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	.bf-pdr-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px;
		margin-bottom: 14px;
	}

	.bf-pdr-status {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted-foreground);
		padding: 3px 10px;
		border-radius: 20px;
		border: 1px solid var(--border);
		background: var(--card);
	}

	.bf-pdr-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		display: inline-block;
		flex-shrink: 0;
	}

	.bf-pdr-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 500;
		background: rgba(var(--primary-rgb), 0.08);
		color: var(--primary);
		padding: 2px 8px;
		border-radius: 20px;
	}

	.bf-pdr-links {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}

	.bf-pdr-cta,
	.bf-pdr-cta-sec {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		text-decoration: none;
		border-radius: 999px;
		padding: 7px 14px;
		font-size: 13px;
	}

	.bf-pdr-cta {
		background: var(--primary);
		color: var(--card);
		font-weight: 600;
	}

	.bf-pdr-cta-sec {
