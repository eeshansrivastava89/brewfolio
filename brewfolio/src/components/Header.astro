---
interface NavItem {
	label: string
	href: string
}

interface Props {
	navItems?: NavItem[]
	siteName?: string
	showSearch?: boolean
	showThemeToggle?: boolean
}

const {
	navItems = [
		{ label: 'Writing', href: '/writing' },
		{ label: 'Analysis', href: '/analysis' },
		{ label: 'About', href: '/about' }
	],
	siteName = 'Eeshan S.',
	showSearch = true,
	showThemeToggle = true
} = Astro.props
---

<div class="fixed top-0 left-0 right-0 flex justify-center z-[65] pointer-events-none">
	<div class="notch" id="notch">
		<strong class="notch-name">{siteName}</strong>
		<span class="notch-sep hidden">›</span>
		<span class="notch-page hidden"></span>
	</div>
</div>

<header class="h-[52px] flex items-center justify-between px-3 gap-2.5">
	<span class="mobile-notch-label" aria-hidden="true">{siteName}</span>
	<div class="flex items-center gap-2">
		<nav class="flex gap-1.5" aria-label="Primary">
			{navItems.map((item) => (
				<a href={item.href} class="nav-pill" data-route={item.href}>
					{item.label}
				</a>
			))}
		</nav>
		{showThemeToggle && (
			<button class="theme-toggle" type="button" id="themeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
				<svg class="theme-icon theme-icon-moon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				<svg class="theme-icon theme-icon-sun w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
			</button>
		)}
		{showSearch && (
			<button class="search-hint" type="button" aria-label="Search">
				<span class="search-hint-desktop">/ search</span>
				<span class="search-hint-mobile">Search</span>
			</button>
		)}
		<slot name="settings-trigger" />
	</div>
</header>

<script is:inline>
	document.getElementById('themeToggle')?.addEventListener('click', function () {
		if (window.__toggleTheme) window.__toggleTheme()
	})
	document.querySelectorAll('.search-hint').forEach(function (button) {
		button.addEventListener('click', function () {
			if (window.__brewfolioOpenSearch) window.__brewfolioOpenSearch()
		})
	})

	document.addEventListener('keydown', function (event) {
		if (event.key === 'd' && !event.ctrlKey && !event.metaKey && !event.altKey) {
			var active = document.activeElement
			if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA')) return
			if (window.__toggleTheme) window.__toggleTheme()
		}
	})
</script>

<style>
	/* Notch uses pseudo-elements + box-shadow to extend the card surface.
	 * Tailwind can't express this — keep scoped. */
	.notch {
		position: relative;
		pointer-events: auto;
		padding: 10px 30px 4px;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.03em;
		color: var(--muted);
		background: var(--card);
		border-left: 1px solid var(--border);
		border-right: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		border-radius: 0 0 14px 14px;
	}

	.notch::before,
	.notch::after {
		content: '';
		position: absolute;
		top: 0;
		width: 14px;
		height: 14px;
		background: transparent;
	}

	.notch::before {
		left: -14px;
		border-top-right-radius: 14px;
		box-shadow: 5px 0 0 0 var(--card);
		border-top: 1px solid var(--border);
		border-right: 1px solid var(--border);
	}

	.notch::after {
		right: -14px;
		border-top-left-radius: 14px;
		box-shadow: -5px 0 0 0 var(--card);
		border-top: 1px solid var(--border);
		border-left: 1px solid var(--border);
	}

	.notch-name {
		color: var(--primary);
		font-weight: 600;
	}

	.notch-sep {
		color: var(--muted);
		margin: 0 6px;
	}

	.notch-page {
		color: var(--foreground);
		font-weight: 500;
	}

	.nav-pill {
		padding: 7px 16px;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: var(--card);
		color: var(--foreground);
		font-family: var(--font-sans);
		font-size: 14px;
		font-weight: 500;
		cursor: pointer;
		transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		touch-action: manipulation;
	}

	.nav-pill:hover,
	.nav-pill.active {
		background: var(--accent);
		border-color: var(--primary);
		color: var(--primary);
		text-decoration: none;
	}

	.nav-pill:focus-visible,
	.theme-toggle:focus-visible,
	.search-hint:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 2px;
	}

	.theme-toggle,
	.search-hint {
		padding: 5px 12px;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: var(--card);
		color: var(--muted-foreground);
		font-family: var(--font-sans);
		font-size: 14px;
		cursor: pointer;
		transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		touch-action: manipulation;
	}

	.theme-toggle {
		padding: 7px 10px;
	}

	.theme-icon {
		display: block;
	}

	:global([data-theme='light']) .theme-icon-sun,
	:global([data-theme='dark']) .theme-icon-moon {
		display: none;
	}

	.search-hint {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted);
	}

	.theme-toggle:hover,
	.search-hint:hover {
		background: var(--accent);
		border-color: var(--primary);
		color: var(--primary);
	}

	.mobile-notch-label {
		display: none;
	}

	.search-hint-mobile {
		display: none;
	}

	@media (max-width: 768px) {
		.fixed {
			display: none;
		}

		header {
			height: auto;
			flex-wrap: wrap;
			padding: 8px 12px;
			gap: 8px;
		}

		.mobile-notch-label {
			display: inline-block;
			order: 1;
			font-family: var(--font-sans);
			font-size: 13px;
			font-weight: 600;
			color: var(--primary);
			letter-spacing: 0.02em;
		}

		header > div {
			order: 2;
			width: 100%;
			gap: 8px;
		}

		nav {
			flex: 1;
			min-width: 0;
			overflow-x: auto;
			flex-wrap: nowrap;
			padding-bottom: 4px;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
		}

		nav::-webkit-scrollbar {
			display: none;
		}

		.nav-pill {
			white-space: nowrap;
			flex-shrink: 0;
			padding: 6px 12px;
			font-size: 13px;
		}

		.theme-toggle {
			padding: 4px 10px;
		}

		.search-hint {
			display: inline-flex;
			padding: 4px 10px;
		}

		.search-hint-desktop {
			display: none;
		}

		.search-hint-mobile {
			display: inline;
			font-family: var(--font-sans);
			font-size: 12px;
			font-weight: 600;
		}
	}
</style>
