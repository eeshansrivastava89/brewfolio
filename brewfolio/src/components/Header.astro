---
interface NavItem {
	label: string
	href: string
}

interface Props {
	navItems?: NavItem[]
	siteName?: string
	showSearch?: boolean
	showThemeToggle?: boolean
	showEditorShortcut?: boolean
	showClockWeather?: boolean
	latitude?: number
	longitude?: number
	timezone?: string
	cityName?: string
}

const {
	navItems = [],
	siteName = 'Portfolio',
	showSearch = true,
	showThemeToggle = true,
	showEditorShortcut = import.meta.env.DEV,
	showClockWeather,
	latitude,
	longitude,
	timezone,
	cityName = '',
} = Astro.props

const hasLocationConfig = (
	typeof latitude === 'number' &&
	Number.isFinite(latitude) &&
	typeof longitude === 'number' &&
	Number.isFinite(longitude) &&
	typeof timezone === 'string' &&
	timezone.length > 0 &&
	typeof cityName === 'string' &&
	cityName.length > 0
)

const shouldShowClockWeather = showClockWeather ?? hasLocationConfig
---

<header class="brewfolio-header">
	<div class="header-left-cluster">
		{shouldShowClockWeather && (
			<div class="header-clock-weather">
				<div class="mini-clock-face" id="miniClockFace" aria-hidden="true">
					<div class="tick-marks">
						{Array.from({ length: 12 }, (_, i) => (
							<div class:list={['tick', i % 3 === 0 && 'major']} style={`transform: rotate(${i * 30}deg)`}></div>
						))}
					</div>
					<div class="clock-center"></div>
					<div class="clock-hand hour" id="miniHourHand"></div>
					<div class="clock-hand minute" id="miniMinuteHand"></div>
					<div class="clock-hand second" id="miniSecondHand"></div>
				</div>
				<div class="digital-clock" id="miniDigitalClock">--:--</div>
				<div class="clock-divider"></div>
				<div class="weather" id="headerWeather">
					<span class="weather-icon" id="weatherIcon">⛅</span>
					<span class="weather-temp" id="weatherTemp">--°F</span>
					<span class="weather-loc">{cityName}</span>
				</div>
			</div>
		)}
		<div class="header-title-box" aria-label={siteName}>
			<strong class="header-title-text">{siteName}</strong>
		</div>
	</div>

	<span class="mobile-title-label" aria-hidden="true">{siteName}</span>

	<div class="header-actions">
		{navItems.length > 0 && (
			<nav class="nav-pills" aria-label="Primary">
				{navItems.map((item) => (
					<a href={item.href} class="nav-pill" data-modal-link data-route={item.href}>
						{item.label}
					</a>
				))}
			</nav>
		)}
		{showEditorShortcut && (
			<a href="/keystatic" target="_blank" rel="noopener noreferrer" class="editor-shortcut" title="Open Keystatic" aria-label="Open Keystatic">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="15" height="15"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06A2 2 0 1 1 7.04 3.4l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 1-1.51V2a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.01a1.65 1.65 0 0 0 1.82-.33l.06-.06A2 2 0 1 1 20.6 7.04l-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51 1H22a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
			</a>
		)}
		{showThemeToggle && (
			<button class="theme-toggle" type="button" id="themeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
				<svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				<svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
			</button>
		)}
		{showSearch && (
			<button class="search-hint" type="button" aria-label="Search">
				<span class="search-hint-desktop">/ search</span>
				<span class="search-hint-mobile">Search</span>
			</button>
		)}
	</div>
</header>

<script is:inline define:vars={{ latitude, longitude, timezone }}>
	(function () {
		var hourHand = document.getElementById('miniHourHand')
		var minuteHand = document.getElementById('miniMinuteHand')
		var secondHand = document.getElementById('miniSecondHand')
		var digitalClock = document.getElementById('miniDigitalClock')

		if (!hourHand || !minuteHand || !secondHand || !digitalClock || !timezone) return

		var partsFormatter = new Intl.DateTimeFormat('en-US', {
			timeZone: timezone,
			hour: 'numeric',
			minute: 'numeric',
			second: 'numeric',
			hour12: false
		})

		function getSitePart(parts, type) {
			var found = parts.find(function (p) { return p.type === type })
			return found ? parseInt(found.value, 10) : 0
		}

		function updateClock() {
			var now = new Date()
			var parts = partsFormatter.formatToParts(now)
			var h = getSitePart(parts, 'hour') % 12
			var m = getSitePart(parts, 'minute')
			var s = getSitePart(parts, 'second')
			var ms = now.getMilliseconds()
			var secondAngle = (s + ms / 1000) * 6
			var minuteAngle = (m + s / 60) * 6
			var hourAngle = (h + m / 60) * 30
			hourHand.style.transform = 'rotate(' + hourAngle + 'deg)'
			minuteHand.style.transform = 'rotate(' + minuteAngle + 'deg)'
			secondHand.style.transform = 'rotate(' + secondAngle + 'deg)'

			var hours24 = getSitePart(parts, 'hour')
			var minutes = String(m).padStart(2, '0')
			var ampm = hours24 >= 12 ? 'PM' : 'AM'
			var h12 = hours24 % 12 || 12
			digitalClock.textContent = h12 + ':' + minutes + ' ' + ampm
		}

		updateClock()
		setInterval(updateClock, 1000)

		var weatherIcon = document.getElementById('weatherIcon')
		var weatherTemp = document.getElementById('weatherTemp')
		var weatherLastFetch = 0
		var hasCoordinates = (
			typeof latitude === 'number' &&
			Number.isFinite(latitude) &&
			typeof longitude === 'number' &&
			Number.isFinite(longitude) &&
			typeof timezone === 'string' &&
			timezone.length > 0
		)

		function weatherEmoji(code) {
			if (code >= 0 && code <= 1) return '☀️'
			if (code >= 2 && code <= 3) return '⛅'
			if (code >= 45 && code <= 48) return '☁️'
			if (code >= 51 && code <= 67) return '🌧️'
			if (code >= 71 && code <= 77) return '❄️'
			if (code >= 80 && code <= 82) return '🌧️'
			if (code >= 95) return '⛈️'
			return '⛅'
		}

		function fetchWeather() {
			if (!hasCoordinates || !weatherIcon || !weatherTemp) return
			var now = Date.now()
			if (now - weatherLastFetch < 30 * 60 * 1000) return
			weatherLastFetch = now
			var url = 'https://api.open-meteo.com/v1/forecast?latitude=' + latitude + '&longitude=' + longitude + '&current=temperature_2m,weather_code&temperature_unit=fahrenheit&timezone=' + encodeURIComponent(timezone)
			fetch(url)
				.then(function (response) { return response.json() })
				.then(function (data) {
					var current = data && data.current
					if (!current) return
					if (typeof current.temperature_2m === 'number') {
						weatherTemp.textContent = Math.round(current.temperature_2m) + '\u00B0F'
					}
					weatherIcon.textContent = weatherEmoji(current.weather_code)
				})
				.catch(function () {})
		}

		fetchWeather()
		setInterval(fetchWeather, 30 * 60 * 1000)
	})()
</script>

<script is:inline>
	document.getElementById('themeToggle')?.addEventListener('click', function () {
		if (window.__toggleTheme) window.__toggleTheme()
	})
	document.querySelectorAll('.search-hint').forEach(function (button) {
		button.addEventListener('click', function () {
			if (window.__brewfolioOpenSearch) window.__brewfolioOpenSearch()
		})
	})

	document.addEventListener('keydown', function (event) {
		if (event.key === 'd' && !event.ctrlKey && !event.metaKey && !event.altKey) {
			var active = document.activeElement
			if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA')) return
			if (window.__toggleTheme) window.__toggleTheme()
		}
	})
</script>

<style>
	.brewfolio-header {
		height: 52px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 12px;
		gap: 10px;
	}

	.header-left-cluster {
		display: flex;
		align-items: center;
		gap: 8px;
		min-width: 0;
	}

	.header-clock-weather,
	.header-title-box,
	.nav-pill,
	.theme-toggle,
	.editor-shortcut,
	.search-hint {
		border-radius: 6px;
		border: 1px solid var(--border);
		background: var(--card);
	}

	.header-clock-weather {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 3px 12px;
	}

	.header-title-box {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 7px 20px;
		min-height: 38px;
		min-width: 0;
		max-width: min(42vw, 28rem);
		flex: 0 1 auto;
	}

	.header-title-text {
		color: var(--primary);
		font-family: var(--font-serif);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.mobile-title-label {
		display: none;
	}

	.mini-clock-face {
		width: 28px;
		height: 28px;
		border-radius: 50%;
		border: 1.5px solid var(--border);
		background: var(--card);
		position: relative;
		flex-shrink: 0;
	}

	.tick-marks {
		position: absolute;
		inset: 0;
	}

	.tick {
		position: absolute;
		top: 2px;
		left: 50%;
		width: 1px;
		height: 4px;
		margin-left: -0.5px;
		background: var(--muted);
		transform-origin: 50% 12px;
		opacity: 0.7;
	}

	.tick.major {
		height: 5px;
		background: var(--foreground);
		opacity: 0.9;
	}

	.clock-center {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 3px;
		height: 3px;
		background: var(--foreground);
		border-radius: 50%;
		transform: translate(-50%, -50%);
		z-index: 4;
	}

	.clock-hand {
		position: absolute;
		bottom: 50%;
		left: 50%;
		transform-origin: 50% 100%;
		border-radius: 1px;
	}

	.clock-hand.hour {
		width: 2px;
		height: 8px;
		background: var(--foreground);
		margin-left: -1px;
		z-index: 3;
	}

	.clock-hand.minute {
		width: 1.5px;
		height: 10px;
		background: var(--foreground);
		margin-left: -0.75px;
		z-index: 2;
	}

	.clock-hand.second {
		width: 1px;
		height: 11px;
		background: var(--primary);
		margin-left: -0.5px;
		z-index: 1;
	}

	.digital-clock,
	.weather-temp {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		color: var(--foreground);
		white-space: nowrap;
	}

	.clock-divider {
		width: 1px;
		height: 18px;
		background: var(--border);
	}

	.weather {
		display: flex;
		align-items: center;
		gap: 5px;
	}

	.weather-icon {
		font-size: 14px;
		line-height: 1;
	}

	.weather-loc {
		font-size: 10px;
		color: var(--muted);
	}

	.nav-pills {
		display: flex;
		gap: 6px;
	}

	.nav-pill {
		padding: 7px 16px;
		color: var(--foreground);
		font-family: var(--font-sans);
		font-size: 14px;
		font-weight: 500;
		cursor: pointer;
		transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		touch-action: manipulation;
	}

	.nav-pill:hover,
	.nav-pill.active {
		background: var(--accent);
		border-color: var(--primary);
		color: var(--primary);
		text-decoration: none;
	}

	.nav-pill:focus-visible,
	.editor-shortcut:focus-visible,
	.theme-toggle:focus-visible,
	.search-hint:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 2px;
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-left: auto;
	}

	.theme-toggle,
	.editor-shortcut,
	.search-hint {
		padding: 5px 12px;
		color: var(--muted-foreground);
		font-family: var(--font-sans);
		font-size: 14px;
		cursor: pointer;
		transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		touch-action: manipulation;
	}

	.theme-toggle,
	.editor-shortcut {
		padding: 7px 10px;
	}

	.theme-icon {
		width: 16px;
		height: 16px;
		display: block;
	}

	:global([data-theme='light']) .theme-icon-sun,
	:global([data-theme='dark']) .theme-icon-moon {
		display: none;
	}

	.search-hint {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted);
	}

	.theme-toggle:hover,
	.editor-shortcut:hover,
	.search-hint:hover {
		background: var(--accent);
		border-color: var(--primary);
		color: var(--primary);
	}

	.search-hint-mobile {
		display: none;
	}

	@media (max-width: 768px) {
		.brewfolio-header {
			height: auto;
			padding: 8px 12px;
			gap: 8px;
			flex-direction: column;
			align-items: stretch;
		}

		.header-left-cluster {
			order: 0;
			width: 100%;
			display: grid;
			grid-template-columns: minmax(0, max-content) minmax(0, 1fr);
			justify-content: stretch;
			align-items: center;
			gap: 10px;
		}

		.header-clock-weather {
			font-size: 12px;
			padding: 2px 8px;
			gap: 6px;
			flex: 0 1 auto;
			min-width: 0;
		}

		.mini-clock-face {
			display: none;
		}

		.header-title-box {
			display: inline-flex;
			min-width: 0;
			width: fit-content;
			max-width: min(46vw, 16rem);
			padding: 6px 14px;
			margin-left: auto;
			justify-self: end;
		}

		.mobile-title-label {
			display: none;
		}

		.header-title-text {
			font-size: 0.95rem;
		}

		.header-actions {
			width: 100%;
			gap: 8px;
			justify-content: stretch;
			flex-wrap: nowrap;
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto auto auto;
			align-items: center;
		}

		.nav-pills {
			grid-column: 1;
			min-width: 0;
			overflow-x: auto;
			flex-wrap: nowrap;
			padding-bottom: 4px;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
		}

		.nav-pills::-webkit-scrollbar {
			display: none;
		}

		.nav-pill {
			white-space: nowrap;
			flex-shrink: 0;
			padding: 6px 11px;
			font-size: 13px;
		}

		.theme-toggle,
		.editor-shortcut {
			padding: 4px 9px;
		}

		.search-hint {
			display: inline-flex;
			padding: 4px 8px;
			white-space: nowrap;
		}

		.search-hint-desktop {
			display: none;
		}

		.search-hint-mobile {
			display: inline;
			font-family: var(--font-sans);
			font-size: 12px;
			font-weight: 600;
		}
	}
</style>
