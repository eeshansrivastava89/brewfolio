---
/**
 * Leaderboard — Ranked list with medal icons, optional "YOU" badge, and score display.
 * Supports gold/silver/bronze medal rendering, current-user highlighting, and optional delta.
 *
 * USE CASES
 *   • Quiz/game leaderboards — quizzard, ab-simulator
 *   • A/B experiment results ranking
 *   • Any ranked list with a score and optional change indicator
 *
 * SOURCE APP: ab-simulator (leaderboard-ui.js), quizzard (host.ts)
 * THIS COMPONENT: Fully static — data passed as props; no JS required for rendering
 *
 * PROPS
 *   entries[]     — { rank, name, score, delta?, isCurrentUser?, variant? }
 *                    variant: 'gold' | 'silver' | 'bronze' | 'default' (for rank ≤3)
 *   title         — list header (default 'Leaderboard')
 *   showDelta     — show score change badge (default false)
 *   showRank      — show rank badge/medal (default true)
 *
 * STYLING NOTES
 *   Medal SVG fill colors (gold/silver/bronze — inline style attributes) — CSS only
 *   Current-user left-border accent — CSS only (.is-you selector)
 *   All layout/spacing/colors — via Tailwind
 */

interface LeaderboardEntry {
	rank: number
	name: string
	score: number | string
	delta?: number | string
	isCurrentUser?: boolean
	variant?: 'gold' | 'silver' | 'bronze' | 'default'
}

interface Props {
	entries: LeaderboardEntry[]
	title?: string
	showDelta?: boolean
	showRank?: boolean
	class?: string
}

const {
	entries,
	title = 'Leaderboard',
	showDelta = false,
	showRank = true,
	class: className = '',
} = Astro.props

const podium = ['gold', 'silver', 'bronze']
---

<div class={`brewfolio-leaderboard rounded-xl border bg-card shadow border-border overflow-hidden
	${className}`}>
	{title && (
		<div class="px-4 py-3 border-b border-input">
			<h3 class="font-serif text-[15px] font-bold text-foreground m-0">{title}</h3>
		</div>
	)}

	<ol class="leaderboard-list list-none m-0 p-0" aria-label={title}>
		{entries.map((entry) => {
			const isTopThree = entry.rank < 4
			const medal = showRank && isTopThree ? podium[entry.rank - 1] : null
			const displayRank = isTopThree ? '' : entry.rank

			return (
				<li class={`leaderboard-entry flex items-center gap-2.5 px-4 py-2.5
					border-b border-input transition-colors duration-100 hover:bg-secondary
					${entry.isCurrentUser ? 'is-you relative' : ''}`}
					data-rank={entry.rank}>
					{showRank && (
						<div class="entry-rank w-8 h-8 flex items-center justify-center shrink-0">
							{medal ? (
								<svg width="16" height="16" viewBox="0 0 24 24"
									fill={medal === 'gold' ? '#CBA258' : medal === 'silver' ? '#9CA3AF' : '#CD7F32'}
									aria-hidden="true">
									<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
								</svg>
							) : (
								<span class="rank-number font-mono text-[13px] font-bold
									text-muted-foreground min-w-[20px] text-center">
									{displayRank}
								</span>
							)}
						</div>
					)}

					<div class="entry-info flex-1 min-w-0 flex items-center gap-2">
						<span class="entry-name text-[14px] font-medium text-foreground
							whitespace-nowrap overflow-hidden text-ellipsis">
							{entry.name}
						</span>
						{entry.isCurrentUser && (
							<span class="you-badge shrink-0 text-[9px] font-bold uppercase
								tracking-wider text-primary bg-[rgba(var(--primary-rgb),0.1)]
								px-1.5 py-0.5 rounded-full border border-[rgba(var(--primary-rgb),0.2)]">
								You
							</span>
						)}
					</div>

					<div class="entry-score-col flex flex-col items-end gap-px shrink-0">
						<span class="entry-score font-mono text-[14px] font-bold text-foreground">
							{typeof entry.score === 'number'
								? entry.score.toLocaleString()
								: entry.score}
						</span>
						{showDelta && entry.delta !== undefined && (
							<span class={`entry-delta font-mono text-[11px] font-medium
								${Number(entry.delta) >= 0 ? 'text-green' : 'text-red'}`}>
								{Number(entry.delta) >= 0 ? '+' : ''}{entry.delta}
							</span>
						)}
					</div>
				</li>
			)
		})}
	</ol>

	{entries.length === 0 && (
		<div class="px-4 py-6 text-center text-[13px] text-muted-foreground italic">
			No entries yet.
		</div>
	)}
</div>

<style>
	/* Current-user left-border accent — CSS only */
	.leaderboard-entry.is-you::before {
		content: '';
		position: absolute;
		left: 0; top: 0; bottom: 0;
		width: 3px;
		background: var(--primary);
		border-radius: 0 2px 2px 0;
	}

	/* Last entry no border */
	.leaderboard-entry:last-child { border-bottom: none; }
</style>
