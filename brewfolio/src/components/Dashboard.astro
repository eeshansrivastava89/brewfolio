---
interface Props {
	title?: string
}

const { title = 'Home' } = Astro.props
---

<div class="brewfolio-dashboard" data-brewfolio-dashboard>
	<slot />
</div>

<script define:vars={{ title }} is:inline>
(function () {
	window.__brewfolioHomeTitle = window.__brewfolioHomeTitle || title

	function normalizePath(path) {
		if (!path) return '/'
		var normalized = path.split('#')[0].split('?')[0]
		if (normalized.length > 1 && normalized.endsWith('/')) {
			normalized = normalized.slice(0, -1)
		}
		return normalized || '/'
	}

	var injectedStylePaths = {}

	function setDocumentTitle(nextTitle) {
		document.title = nextTitle || window.__brewfolioHomeTitle || title
	}

	function notchSectionForPath(normalized) {
		if (!normalized || normalized === '/') return null
		var sectionNames = {
			'/writing': 'Writing',
			'/analysis': 'Analysis',
			'/about': 'About',
		}
		if (sectionNames[normalized]) return sectionNames[normalized]
		var parts = normalized.split('/').filter(Boolean)
		if (parts.length >= 1) {
			var parent = '/' + parts[0]
			if (sectionNames[parent]) return sectionNames[parent]
		}
		return null
	}

	function updateNotchForPath(normalized) {
		var notch = document.getElementById('notch')
		if (!notch) return
		var sep = notch.querySelector('.notch-sep')
		var pageEl = notch.querySelector('.notch-page')
		if (!sep || !pageEl) return
		var section = notchSectionForPath(normalized)
		if (section) {
			pageEl.textContent = section
			sep.hidden = false
			pageEl.hidden = false
			return
		}
		sep.hidden = true
		pageEl.hidden = true
		pageEl.textContent = ''
	}

	function updateNavActive(path) {
		var normalized = normalizePath(path || window.location.pathname)
		document.querySelectorAll('.nav-pill[data-route]').forEach(function (pill) {
			var route = pill.getAttribute('data-route') || ''
			var active = normalized !== '/' && (normalized === route || normalized.indexOf(route + '/') === 0)
			pill.classList.toggle('active', active)
		})
		updateNotchForPath(normalized)
	}

	function clearHighlights() {
		document.querySelectorAll('.concept-row').forEach(function (row) {
			row.classList.remove('active')
			row.setAttribute('aria-pressed', 'false')
		})
		document.querySelectorAll('.project-tile').forEach(function (tile) {
			tile.classList.remove('highlighted', 'dimmed')
		})
		document.querySelectorAll('.writing-row').forEach(function (row) {
			row.classList.remove('highlighted', 'dimmed')
		})
		document.querySelectorAll('.analysis-row').forEach(function (row) {
			row.classList.remove('highlighted', 'dimmed')
		})
	}

	function conceptMapFromDom() {
		var map = {}
		document.querySelectorAll('.concept-row[data-concept]').forEach(function (row) {
			var slug = row.getAttribute('data-concept') || ''
			if (!slug) return
			map[slug] = {
				projects: (row.getAttribute('data-projects') || '').split(',').filter(Boolean),
				writing: (row.getAttribute('data-writing') || '').split(',').filter(Boolean),
				notebooks: (row.getAttribute('data-notebooks') || '').split(',').filter(Boolean),
			}
		})
		return map
	}

	function toggleConcept(slug) {
		if (!slug) return
		var current = window.__brewfolioActiveConcept || null
		if (current === slug) {
			window.__brewfolioActiveConcept = null
			clearHighlights()
			return
		}

		window.__brewfolioActiveConcept = slug
		clearHighlights()
		var conceptMap = conceptMapFromDom()
		var linked = conceptMap[slug] || { projects: [], writing: [], notebooks: [] }

		document.querySelectorAll('.concept-row').forEach(function (row) {
			var isActive = row.getAttribute('data-concept') === slug
			row.classList.toggle('active', isActive)
			row.setAttribute('aria-pressed', isActive ? 'true' : 'false')
		})

		document.querySelectorAll('.project-tile').forEach(function (tile) {
			var projectId = tile.getAttribute('data-project-id') || ''
			var hasMatch = linked.projects.indexOf(projectId) !== -1
			tile.classList.toggle('highlighted', hasMatch)
			tile.classList.toggle('dimmed', !hasMatch)
		})

		document.querySelectorAll('.writing-row').forEach(function (row) {
			var writingSlug = row.getAttribute('data-writing') || ''
			var hasMatch = linked.writing.indexOf(writingSlug) !== -1
			row.classList.toggle('highlighted', hasMatch)
			row.classList.toggle('dimmed', !hasMatch)
		})

		document.querySelectorAll('.analysis-row').forEach(function (row) {
			var notebookSlug = row.getAttribute('data-notebook-slug') || ''
			var hasMatch = linked.notebooks.indexOf(notebookSlug) !== -1
			row.classList.toggle('highlighted', hasMatch)
			row.classList.toggle('dimmed', !hasMatch)
		})
	}

	function parseFetchedModalDocument(doc, fallbackPath) {
		var source = doc.querySelector('[data-brewfolio-modal-source]')
		if (!source) return null
		var left = source.querySelector('[data-brewfolio-modal-left]')
		var center = source.querySelector('[data-brewfolio-modal-center]')
		var right = source.querySelector('[data-brewfolio-modal-right]')
		var body = source.querySelector('[data-brewfolio-modal-body]')
		var titleEl = doc.querySelector('title')
		return {
			path: normalizePath(source.getAttribute('data-path') || fallbackPath || (doc.location && doc.location.pathname) || '/'),
			size: source.getAttribute('data-size') || 'default',
			left: left ? left.innerHTML : '',
			center: center ? center.innerHTML : '',
			right: right ? right.innerHTML : '',
			body: body ? body.innerHTML : '',
			title: titleEl ? titleEl.textContent : '',
		}
	}

	function getCurrentDocumentModalSource(path) {
		var source = document.querySelector('[data-brewfolio-modal-source]')
		if (!source) return null
		var sourcePath = normalizePath(source.getAttribute('data-path') || window.location.pathname)
		if (path && sourcePath !== normalizePath(path)) return null
		return parseFetchedModalDocument(document, sourcePath)
	}

	function focusProject(projectId) {
		if (!projectId) return
		var projectTile = document.querySelector('.project-tile[data-project-id="' + projectId + '"]')
		if (!projectTile) return
		projectTile.scrollIntoView({ behavior: 'smooth', block: 'center' })
		projectTile.classList.add('project-focus-pulse')
		setTimeout(function () {
			projectTile.classList.remove('project-focus-pulse')
		}, 1600)
		var firstLink = projectTile.querySelector('a')
		if (firstLink) firstLink.focus()
	}

	function navigateHome(options) {
		var config = options || {}
		if (config.clearConcept !== false) {
			window.__brewfolioActiveConcept = null
			clearHighlights()
		}
		if (window.__brewfolioCloseModal) window.__brewfolioCloseModal()
		setDocumentTitle(window.__brewfolioHomeTitle || title)
		updateNavActive('/')
		if (config.push !== false && normalizePath(window.location.pathname) !== '/') {
			history.pushState({ modal: false, path: '/' }, '', '/')
		}
	}

	async function openModalForPath(path, options) {
		var config = options || {}
		var normalized = normalizePath(path)
		if (normalized === '/') {
			navigateHome(config)
			return
		}

		if (window.__brewfolioCloseSearch) window.__brewfolioCloseSearch()

		var modalData = getCurrentDocumentModalSource(normalized)
		if (!modalData) {
			var response = await fetch(normalized)
			if (!response.ok) {
				console.warn('[brewfolio] Fetch failed for', normalized, response.status, '— falling back to home')
				navigateHome({ push: true })
				return
			}
			var html = await response.text()
			var parser = new DOMParser()
			var doc = parser.parseFromString(html, 'text/html')
			modalData = parseFetchedModalDocument(doc, normalized)

			if (!injectedStylePaths[normalized]) {
				injectedStylePaths[normalized] = true
				doc.querySelectorAll('head style').forEach(function (styleEl) {
					document.head.appendChild(document.adoptNode(styleEl))
				})
			}
		}

		if (!modalData || !window.__brewfolioOpenModal) {
			console.warn('[brewfolio] No modal source for', normalized, '— falling back to home')
			navigateHome({ push: true })
			return
		}

		window.__brewfolioOpenModal(modalData.center, modalData.right, modalData.left, modalData.body, modalData.size)
		setDocumentTitle(modalData.title)
		updateNavActive(normalized)

		if (config.push !== false && normalizePath(window.location.pathname) !== normalized) {
			history.pushState({ modal: true, path: normalized }, '', normalized)
		}
	}

	async function syncRouteToModal() {
		var path = normalizePath(window.location.pathname)
		if (path === '/') {
			navigateHome({ push: false, clearConcept: false })
			return
		}
		await openModalForPath(path, { push: false })
	}

	window.__brewfolioToggleConcept = toggleConcept
	window.__brewfolioOpenPathModal = openModalForPath
	window.__brewfolioNavigateHome = function () {
		navigateHome({ push: true, clearConcept: false })
	}
	window.__brewfolioFocusProject = function (projectId) {
		navigateHome({ push: true, clearConcept: false })
		focusProject(projectId)
	}

	document.addEventListener('click', function (event) {
		if (window.__brewfolioActiveConcept && !event.target.closest('.pane-concepts')) {
			window.__brewfolioActiveConcept = null
			clearHighlights()
		}

		var modalLink = event.target.closest('a[data-modal-link]')
		if (modalLink) {
			if (event.metaKey || event.ctrlKey || event.shiftKey || event.button !== 0) return
			event.preventDefault()
			openModalForPath(modalLink.getAttribute('href') || '/')
			return
		}

		var conceptTrigger = event.target.closest('[data-concept-filter]')
		if (conceptTrigger) {
			event.preventDefault()
			toggleConcept(conceptTrigger.getAttribute('data-concept-filter') || '')
			return
		}

		var projectFocus = event.target.closest('[data-project-focus]')
		if (projectFocus) {
			event.preventDefault()
			window.__brewfolioFocusProject(projectFocus.getAttribute('data-project-focus') || '')
			return
		}

		var pane = event.target.closest('.pane')
		if (pane) {
			document.querySelectorAll('.pane').forEach(function (candidate) {
				candidate.classList.remove('focused')
			})
			pane.classList.add('focused')
		}
	}, true)

	window.addEventListener('popstate', function () {
		syncRouteToModal()
	})

	document.addEventListener('keydown', function (event) {
		if (event.key === 'Escape' && window.__brewfolioActiveConcept) {
			window.__brewfolioActiveConcept = null
			clearHighlights()
		}
	})

	document.addEventListener('DOMContentLoaded', function () {
		updateNavActive(window.location.pathname)
		syncRouteToModal()
	})
})()
</script>

<style is:global>
	.brewfolio-dashboard {
		display: grid;
		grid-template-columns: 30fr 40fr 30fr;
		grid-template-rows: minmax(0, 55fr) minmax(0, 45fr);
		gap: 12px;
		height: 100%;
		min-height: 0;
	}

	.pane {
		position: relative;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
		display: flex;
		flex-direction: column;
		overflow: hidden;
		min-height: 0;
		transition: box-shadow 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
	}

	.pane:hover {
		box-shadow: var(--shadow-hover);
	}

	.pane.focused {
		border-color: var(--primary);
		box-shadow: var(--shadow-hover);
	}

	.pane-header,
	.writing-pane-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		padding: 10px 14px;
		border-bottom: 1px solid var(--input);
		flex-shrink: 0;
	}

	.pane-header h2,
	.writing-pane-header h2 {
		font-family: var(--font-serif);
		font-size: 17px;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--foreground);
	}

	.pane-header-link,
	.writing-pane-header-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		color: inherit;
		min-width: 0;
	}

	.pane-header-link:hover,
	.writing-pane-header-link:hover {
		color: var(--primary);
		text-decoration: none;
	}

	.pane-header-right {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.pane-body {
		flex: 1;
		min-height: 0;
		overflow-y: auto;
		scrollbar-width: none;
		padding: 8px 0;
	}

	.pane-body::-webkit-scrollbar {
		display: none;
	}

	.pane-concepts { grid-column: 1; grid-row: 1; }
	.pane-github { grid-column: 1; grid-row: 2; }
	.pane-projects { grid-column: 2; grid-row: 1 / 3; }
	.pane-writing { grid-column: 3; grid-row: 1; }
	.pane-analysis { grid-column: 3; grid-row: 2; }

	@media (max-width: 768px) {
		.brewfolio-dashboard {
			display: flex;
			flex-direction: column;
			height: auto;
		}

		.pane {
			min-height: 220px;
		}

		.pane-concepts { order: 1; }
		.pane-writing { order: 2; }
		.pane-projects { order: 3; min-height: 320px; }
		.pane-analysis { order: 4; }
		.pane-github { order: 5; }

		.pane-body {
			max-height: none;
		}
	}

	@media (min-width: 769px) and (max-width: 1024px) {
		.brewfolio-dashboard {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: auto;
			height: auto;
		}

		.pane-concepts { grid-column: 1; grid-row: auto; }
		.pane-writing { grid-column: 2; grid-row: auto; }
		.pane-projects { grid-column: 1 / 3; grid-row: auto; }
		.pane-analysis { grid-column: 1; grid-row: auto; }
		.pane-github { grid-column: 2; grid-row: auto; }
	}
</style>
