---
/**
 * DataTable — Sortable, filterable, paginated table.
 * Client-side sorting (click column headers) and pagination.
 * Data is passed as a JSON array; column definitions specify keys, labels, and alignment.
 *
 * USE CASES
 *   • Benchmark results tables — models, F1 scores, latency, memory usage
 *   • Any tabular data that needs sorting and pagination without a backend
 *   • Works well inside dashboards, analysis panels, leaderboard views
 *
 * SOURCE APP: llm-bench (uses simple-datatables library)
 * THIS COMPONENT: Fully client-side JS, no external library dependency
 *
 * PROPS
 *   columns[]   — { key, label, sortable?, width?, align? }
 *   data[]      — array of objects with keys matching column definitions
 *   pageSize    — rows per page (default 10)
 *   caption     — optional accessible table caption
 *
 * STYLING NOTES
 *   Scrollbar — CSS only
 *   Sort icon visibility (contextual [aria-sort] selectors) — CSS only
 *   border-collapse — CSS only (Tailwind can't express this)
 *   Page button disabled state — CSS only
 *   All layout/spacing/colors — via Tailwind vars and inline styles
 */

type SortDirection = 'asc' | 'desc'

interface Column {
	key: string
	label: string
	sortable?: boolean
	width?: string
	align?: 'left' | 'center' | 'right'
}

interface Props {
	columns: Column[]
	data: Record<string, unknown>[]
	pageSize?: number
	caption?: string
	class?: string
}

const {
	columns,
	data,
	pageSize = 10,
	caption,
	class: className = '',
} = Astro.props

const pageSizeNum = Math.max(1, parseInt(String(pageSize)) || 10)
---

<div class={`brewfolio-datatable rounded-xl border bg-card shadow border-border overflow-hidden
	font-sans ${className}`} data-page-size={pageSizeNum}>
	<div class="table-scroll overflow-x-auto">
		<table class="data-table w-full border-collapse" aria-label={caption || 'Data table'}>
			{caption && <caption class="table-caption">{caption}</caption>}
			<thead class="bg-secondary border-b border-border">
				<tr>
					{columns.map((col) => (
						<th
							class={`col-${col.key} ${col.sortable ? 'sortable' : ''}`}
							style={`${col.width ? `width: ${col.width};` : ''} text-align: ${col.align || 'left'}`}
							data-sort-key={col.key}
							aria-sort="none"
						>
							<span class="th-content inline-flex items-center gap-1.5">
								{col.label}
								{col.sortable && (
									<span class="sort-icons flex flex-col gap-px" aria-hidden="true">
										<svg class="sort-asc w-2.5 h-2.5" viewBox="0 0 10 10" fill="currentColor"><path d="M5 2L8 6H2L5 2Z"/></svg>
										<svg class="sort-desc w-2.5 h-2.5" viewBox="0 0 10 10" fill="currentColor"><path d="M5 8L2 4H8L5 8Z"/></svg>
									</span>
								)}
							</span>
						</th>
					))}
				</tr>
			</thead>
			<tbody>
				{data.map((row) => (
					<tr>
						{columns.map((col) => (
							<td style={`text-align: ${col.align || 'left'}`}>{String(row[col.key] ?? '')}</td>
						))}
					</tr>
				))}
			</tbody>
		</table>
	</div>

	<div class="flex items-center justify-between px-3.5 py-2 border-t border-input bg-secondary gap-3">
		<span class="row-count text-[12px] text-muted-foreground" aria-live="polite"></span>
		<div class="flex items-center gap-2" role="navigation" aria-label="Table pagination">
			<button class="page-btn w-7 h-7 inline-flex items-center justify-center
				border border-border rounded-lg bg-card text-muted-foreground
				cursor-pointer transition-all duration-150" aria-label="Previous page" disabled>
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
					stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<polyline points="15 18 9 12 15 6"/>
				</svg>
			</button>
			<span class="page-info text-[12px] text-muted-foreground min-w-[80px] text-center" aria-live="polite"></span>
			<button class="page-btn w-7 h-7 inline-flex items-center justify-center
				border border-border rounded-lg bg-card text-muted-foreground
				cursor-pointer transition-all duration-150" aria-label="Next page" disabled>
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
					stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<polyline points="9 18 15 12 9 6"/>
				</svg>
			</button>
		</div>
	</div>
</div>

<script is:inline>
(function () {
	function initDataTable(el) {
		const table = el.querySelector('.data-table')
		const tbody = el.querySelector('tbody')
		const prevBtn = el.querySelector('.prev-btn')
		const nextBtn = el.querySelector('.next-btn')
		const rowCountEl = el.querySelector('.row-count')
		const pageInfoEl = el.querySelector('.page-info')
		const pageSize = parseInt(el.getAttribute('data-page-size')) || 10

		if (!table || !tbody) return

		let allData = []
		let sortKey = ''
		let sortDir = 'asc'
		let currentPage = 1

		const headers = el.querySelectorAll('th[data-sort-key]')
		headers.forEach((th) => {
			th.addEventListener('click', () => {
				const key = th.getAttribute('data-sort-key')
				if (!key) return
				if (sortKey === key) {
					sortDir = sortDir === 'asc' ? 'desc' : 'asc'
				} else {
					sortKey = key
					sortDir = 'asc'
				}
				headers.forEach((h) => h.setAttribute('aria-sort', 'none'))
				th.setAttribute('aria-sort', sortDir === 'asc' ? 'ascending' : 'descending')
				currentPage = 1
				render()
			})
		})

		function getSorted() {
			if (!sortKey) return [...allData]
			return [...allData].sort((a, b) => {
				const av = a[sortKey]; const bv = b[sortKey]
				let cmp = typeof av === 'number' && typeof bv === 'number'
					? av - bv
					: String(av || '').localeCompare(String(bv || ''))
				return sortDir === 'asc' ? cmp : -cmp
			})
		}

		function getPageData() {
			const sorted = getSorted()
			const start = (currentPage - 1) * pageSize
			return sorted.slice(start, start + pageSize)
		}

		function totalPages() {
			return Math.max(1, Math.ceil(allData.length / pageSize))
		}

		function render() {
			const pageData = getPageData()
			const total = totalPages()

			tbody.innerHTML = pageData.length === 0
				? '<tr><td colspan="100" class="empty-row text-center text-muted-foreground italic py-7 px-3.5">No data available</td></tr>'
				: pageData.map((row) => {
					const cells = Array.from(table.querySelectorAll('th[data-sort-key]')).map((th) => {
						const key = th.getAttribute('data-sort-key')
						const align = th.style.textAlign || 'left'
						const val = row[key]
						const formatted = val === null || val === undefined
							? '—'
							: typeof val === 'boolean'
							? val ? 'Yes' : 'No'
							: String(val)
						return `<td style="text-align: ${align}" class="px-3.5 py-2.5 text-foreground align-middle">${formatted}</td>`
					}).join('')
					return `<tr class="border-b border-input transition-colors duration-100 hover:bg-secondary">${cells}</tr>`
				}).join('')

			if (rowCountEl) {
				rowCountEl.textContent = allData.length === 0
					? 'No results'
					: `Showing ${((currentPage - 1) * pageSize) + 1}–${Math.min(currentPage * pageSize, allData.length)} of ${allData.length}`
			}
			if (pageInfoEl) pageInfoEl.textContent = allData.length === 0 ? '' : `Page ${currentPage} of ${total}`
			if (prevBtn) prevBtn.disabled = currentPage <= 1
			if (nextBtn) nextBtn.disabled = currentPage >= total
		}

		function loadData() {
			try {
				const rows = table.querySelectorAll('tbody tr')
				const keys = Array.from(table.querySelectorAll('th[data-sort-key]')).map((th) => th.getAttribute('data-sort-key'))
				allData = Array.from(rows).map((row) => {
					const cells = row.querySelectorAll('td')
					const obj = {}
					cells.forEach((cell, i) => { if (keys[i]) obj[keys[i]] = cell.textContent?.trim() || '' })
					return obj
				})
				render()
			} catch {}
		}

		prevBtn?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; render() } })
		nextBtn?.addEventListener('click', () => { if (currentPage < totalPages()) { currentPage++; render() } })

		loadData()
	}

	document.querySelectorAll('.brewfolio-datatable').forEach(initDataTable)
})()
</script>

<style>
	thead th {
		padding: 9px 14px;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted-foreground);
		white-space: nowrap;
		user-select: none;
	}

	th.sortable { cursor: pointer; }
	th.sortable:hover { color: var(--foreground); }

	/* Sort icon visibility — CSS only (contextual attribute selectors) */
	th.sortable:hover .sort-icons,
	th[aria-sort='ascending'] .sort-asc,
	th[aria-sort='descending'] .sort-desc {
		opacity: 1;
		color: var(--primary);
	}
	th[aria-sort='descending'] .sort-asc,
	th[aria-sort='ascending'] .sort-desc { opacity: 0.2; }

	.page-btn:disabled { opacity: 0.35; cursor: not-allowed; }
	.page-btn:hover:not(:disabled) {
		border-color: var(--primary);
		color: var(--primary);
	}

	.table-scroll::-webkit-scrollbar { height: 5px; }
	.table-scroll::-webkit-scrollbar-track { background: transparent; }
	.table-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
</style>
