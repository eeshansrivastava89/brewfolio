---
/**
 * Notebook Summary Card - Card for notebook catalog
 */

interface Notebook {
  id: string
  title: string
  description?: string
  github_url?: string
  date: string
}

interface Project {
  name: string
}

interface Props {
  notebook: Notebook
  project: Project
}

const { notebook, project } = Astro.props

function formatDate(iso: string): string {
  const d = new Date(iso)
  if (isNaN(d.getTime())) return iso
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  })
}
---

<article class="notebook-card group">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="text-xs font-mono text-muted-foreground/70 mb-1.5">
        {project.name}
      </div>
      <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors">
        {notebook.title}
      </h3>
      {notebook.description && (
        <p class="mt-1.5 text-sm text-muted-foreground line-clamp-2">
          {notebook.description}
        </p>
      )}
    </div>
    {notebook.github_url && (
      <a
        href={notebook.github_url}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 p-2 rounded-md hover:bg-muted transition-colors text-muted-foreground hover:text-foreground"
        aria-label="View on GitHub"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
          />
        </svg>
      </a>
    )}
  </div>
  <div class="mt-3 pt-3 border-t border-border/50">
    <time class="text-xs font-mono text-muted-foreground/70" datetime={notebook.date}>
      {formatDate(notebook.date)}
    </time>
  </div>
</article>

<style>
  .notebook-card {
    padding: 16px 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--card);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .notebook-card:hover {
    border-color: var(--primary/30);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  @media (prefers-color-scheme: dark) {
    .notebook-card:hover {
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }
  }
</style>
