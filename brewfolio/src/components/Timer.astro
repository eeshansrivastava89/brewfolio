---
/**
 * Timer — Countdown or count-up timer with urgency states and an optional progress bar.
 * Tick-driven display update every 250ms; fires `timer-complete` when countdown hits zero.
 * Supports pause/resume/reset via CustomEvents dispatched on the element.
 *
 * USE CASES
 *   • Quiz game countdown — quizzard (countdown, warning at 50%, danger at 20%)
 *   • A/B test time tracking (count-up)
 *   • Any precision timer with urgency indicators
 *
 * SOURCE APP: quizzard (countdown bar), ab-simulator (core.js timer)
 * CONCEPTS: countdown/countup variants; starbucks-gold → amber → red urgency colors
 *
 * PROPS
 *   variant      — 'countdown' (default) or 'countup'
 *   totalMs      — total time in ms (default 60000 = 60s)
 *   startedAt    — unix timestamp (ms) to calculate elapsed from (for countup)
 *   showBar      — show progress bar (default true)
 *   showDigits   — show MM:SS digits (default true)
 *   size         — 'sm' | 'md' | 'lg' (controls digit + bar size, default 'md')
 *
 * EVENTS (dispatch on element)
 *   'timer-pause'  — pause the timer
 *   'timer-resume' — resume after pause
 *   'timer-reset'  — reset to initial state
 *   'timer-complete' — fired when countdown reaches 0
 *
 * STYLING NOTES
 *   @keyframes urgentPulse (opacity alternation in danger state) — CSS only
 *   .sr-only screen-reader only text — CSS only
 *   Urgency color changes (warning/danger) via class toggle — CSS only
 *   All layout/spacing/colors — via Tailwind
 */

type TimerVariant = 'countdown' | 'countup'

interface Props {
	variant?: TimerVariant
	totalMs?: number
	startedAt?: number
	showBar?: boolean
	showDigits?: boolean
	size?: 'sm' | 'md' | 'lg'
	class?: string
}

const {
	variant = 'countdown',
	totalMs = 60000,
	startedAt,
	showBar = true,
	showDigits = true,
	size = 'md',
	class: className = '',
} = Astro.props

const timerId = `timer-${Math.random().toString(36).slice(2, 8)}`
---

<div
	class={`brewfolio-timer ${className}`}
	id={timerId}
	data-variant={variant}
	data-total={totalMs}
	data-started={startedAt || ''}
	data-show-bar={showBar ? 'true' : 'false'}
	data-size={size}
>
	<div class="timer-layout flex flex-col gap-2.5 items-start">
		{showDigits && (
			<div class="timer-digits" aria-live="off" aria-label="Timer">
				<span class="digit-display font-mono text-[40px] font-bold tracking-[-0.02em]
					text-foreground font-variant-numeric tabular-nums leading-none
					transition-colors duration-300" aria-hidden="true">00:00</span>
				<span class="sr-only">0 minutes, 0 seconds remaining</span>
			</div>
		)}

		{showBar && (
			<div class="timer-bar-track w-full h-2 bg-input rounded-full overflow-hidden" aria-hidden="true">
				<div class="timer-bar-fill h-full bg-primary rounded-full
					transition-all duration-300"></div>
			</div>
		)}
	</div>
</div>

<script is:inline>
(function () {
	function initTimer(el) {
		const variant = el.getAttribute('data-variant') || 'countdown'
		const totalMs = parseInt(el.getAttribute('data-total')) || 60000
		const startedAt = parseInt(el.getAttribute('data-started')) || null
		const barFill = el.querySelector('.timer-bar-fill')
		const digitDisplay = el.querySelector('.digit-display')
		const srOnly = el.querySelector('.sr-only')

		let remaining = variant === 'countdown' ? totalMs : 0
		let startTime = Date.now()
		if (startedAt && variant === 'countup') {
			startTime = startedAt
			remaining = Date.now() - startedAt
		}
		if (startedAt && variant === 'countdown') {
			remaining = Math.max(0, totalMs - (Date.now() - startedAt))
		}

		function formatMs(ms) {
			const totalSec = Math.floor(Math.abs(ms) / 1000)
			const min = Math.floor(totalSec / 60)
			const sec = totalSec % 60
			const sign = variant === 'countdown' && ms <= 0 ? '-' : ''
			return `${sign}${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}`
		}

		function getUrgency(pct) {
			if (variant !== 'countdown') return 'normal'
			if (pct <= 0.2) return 'danger'
			if (pct <= 0.5) return 'warning'
			return 'normal'
		}

		function render() {
			const elapsed = Date.now() - startTime
			if (variant === 'countdown') {
				remaining = Math.max(0, totalMs - elapsed)
			} else {
				remaining = elapsed
			}

			const pct = totalMs > 0 ? remaining / totalMs : 1
			const urgency = getUrgency(pct)

			el.classList.toggle('warning', urgency === 'warning')
			el.classList.toggle('danger', urgency === 'danger')

			if (digitDisplay) {
				digitDisplay.textContent = formatMs(remaining)
				if (urgency === 'warning') digitDisplay.style.color = '#eab308'
				else if (urgency === 'danger') digitDisplay.style.color = 'var(--red)'
				else digitDisplay.style.color = 'var(--foreground)'
			}

			if (srOnly && variant === 'countdown') {
				const totalSec = Math.floor(remaining / 1000)
				const min = Math.floor(totalSec / 60)
				const sec = totalSec % 60
				srOnly.textContent = `${min} minute${min !== 1 ? 's' : ''}, ${sec} second${sec !== 1 ? 's' : ''} remaining`
			}

			if (barFill) {
				barFill.style.width = `${Math.max(0, Math.min(100, pct * 100))}%`
				if (urgency === 'warning') {
					barFill.classList.add('warning')
					barFill.classList.remove('danger')
					barFill.style.background = '#eab308'
				} else if (urgency === 'danger') {
					barFill.classList.add('danger')
					barFill.classList.remove('warning')
					barFill.style.background = 'var(--red)'
				} else {
					barFill.classList.remove('warning', 'danger')
					barFill.style.background = 'var(--primary)'
				}
			}

			if (variant === 'countdown' && remaining <= 0) {
				el.dispatchEvent(new CustomEvent('timer-complete', { bubbles: true }))
			}
		}

		let interval = setInterval(render, 250)
		render()

		el.addEventListener('timer-pause', () => clearInterval(interval))
		el.addEventListener('timer-resume', () => { interval = setInterval(render, 250) })
		el.addEventListener('timer-reset', () => {
			clearInterval(interval)
			startTime = Date.now()
			remaining = variant === 'countdown' ? totalMs : 0
			render()
			interval = setInterval(render, 250)
		})
	}

	document.querySelectorAll('.brewfolio-timer').forEach(initTimer)
})()
</script>

<style>
	/* Size variants via attribute selectors — CSS only */
	.brewfolio-timer[data-size='sm'] .digit-display { font-size: 24px; }
	.brewfolio-timer[data-size='lg'] .digit-display { font-size: 64px; }
	.brewfolio-timer[data-size='sm'] .timer-bar-track { height: 4px; }
	.brewfolio-timer[data-size='lg'] .timer-bar-track { height: 12px; }

	/* Danger pulse animation — CSS only (Tailwind can't express keyframes) */
	.brewfolio-timer.danger .digit-display {
		animation: urgentPulse 0.5s ease-in-out infinite alternate;
	}

	.sr-only {
		position: absolute;
		width: 1px; height: 1px;
		padding: 0; margin: -1px;
		overflow: hidden;
		clip: rect(0,0,0,0);
		white-space: nowrap;
		border-width: 0;
	}

	@keyframes urgentPulse {
		from { opacity: 1; }
		to { opacity: 0.6; }
	}

	@media (prefers-reduced-motion: reduce) {
		.brewfolio-timer.danger .digit-display { animation: none; }
	}
</style>
