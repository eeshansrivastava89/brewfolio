---
/**
 * Work Timeline - Vertical timeline with left-border accent and dot indicators
 * Work entries use primary color, education entries use blue
 */

interface TimelineEntry {
  timespan?: string
  title: string
  company?: string
  description?: string
  type: 'work' | 'education'
  logo?: string
}

interface Props {
  entries: TimelineEntry[]
}

const { entries } = Astro.props
---

<div class="relative">
  <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border" />

  <div class="space-y-1">
    {entries.map((entry) => {
      const isCurrent = entry.timespan?.includes('Present')
      const isEducation = entry.type === 'education'
      const hasContent = entry.description

      return (
        <div class="relative pl-7 group">
          <div
            class:list={[
              'absolute left-0 top-[10px] h-[15px] w-[15px] rounded-full border-2 transition-all duration-300',
              isCurrent
                ? 'border-emerald-500 bg-emerald-500'
                : isEducation
                  ? 'border-sky-400 bg-background group-hover:bg-sky-400'
                  : 'border-primary/40 bg-background group-hover:bg-primary/40'
            ]}
          />

          <div class="py-2.5 hover:bg-muted/30 -ml-2 pl-2 pr-2 rounded transition-colors duration-200">
            <div class="flex items-baseline justify-between gap-4">
              <div class="flex-1 min-w-0">
                <span class="text-base font-semibold text-foreground">{entry.title}</span>
                {entry.company && (
                  <span class="text-base text-muted-foreground"> · {entry.company}</span>
                )}
              </div>
              {entry.timespan && (
                <span
                  class:list={[
                    'text-sm tabular-nums shrink-0',
                    isCurrent
                      ? 'text-emerald-600 dark:text-emerald-400 font-medium'
                      : isEducation
                        ? 'text-sky-600 dark:text-sky-400'
                        : 'text-muted-foreground'
                  ]}
                >
                  {entry.timespan}
                </span>
              )}
            </div>

            {hasContent && (
              <div class="accordion-content max-h-0 overflow-hidden opacity-0 group-hover:max-h-96 group-hover:opacity-100">
                <div class="pt-2 pb-1">
                  <p class="text-sm text-muted-foreground leading-relaxed">{entry.description}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      )
    })}
  </div>
</div>

<style>
  .accordion-content {
    transition:
      max-height 400ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 300ms ease-out;
    transition-delay: 150ms;
  }

  .group:hover .accordion-content {
    transition:
      max-height 500ms cubic-bezier(0.0, 0, 0.2, 1),
      opacity 400ms ease-out;
    transition-delay: 0ms;
  }
</style>
