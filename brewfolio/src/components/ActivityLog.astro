---
/**
 * ActivityLog — Scrollable, timestamped event log with severity icons.
 * Renders a list of log entries (info/success/warning/error/debug) each with a
 * timestamp, icon, message, and optional detail line.
 *
 * USE CASES
 *   • Scan/analysis progress panels — llm-bench, sidequests
 *   • Build/CI output logs
 *   • Any scrollable feed of timestamped events
 *
 * SOURCE APP: sidequests (ActivityLogPanel.tsx)
 *
 * PROPS
 *   entries[]       — array of { id?, timestamp?, level?, message, details? }
 *   maxHeight       — CSS max-height for the scroll container (default '320px')
 *   showTimestamp   — whether to render HH:MM:SS timestamps (default true)
 *
 * STYLING NOTES
 *   Scrollbar — CSS only
 *   Severity icon colors — CSS only (using .log-entry--{level} classes)
 *   All layout/spacing — via Tailwind
 */

type LogLevel = 'info' | 'success' | 'warning' | 'error' | 'debug'

interface LogEntry {
	id?: string
	timestamp?: number
	level?: LogLevel
	message: string
	details?: string
}

interface Props {
	entries?: LogEntry[]
	maxHeight?: string
	showTimestamp?: boolean
	class?: string
}

const {
	entries = [],
	maxHeight = '320px',
	showTimestamp = true,
	class: className = '',
} = Astro.props
---

<div class={`brewfolio-activitylog rounded-xl border bg-card shadow border-border overflow-hidden
	${className}`} style={`--log-max-height: ${maxHeight}`}>
	<div class="log-container overflow-y-auto py-1.5" role="log" aria-live="polite" aria-label="Activity log">
		{entries.length === 0 ? (
			<div class="flex flex-col items-center justify-center gap-2 px-4 py-8
				text-muted-foreground text-[13px] italic">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
					stroke-width="1.5" aria-hidden="true">
					<path d="M12 8v4l3 3"/>
					<circle cx="12" cy="12" r="9"/>
				</svg>
				<span>Activity will appear here…</span>
			</div>
		) : (
			entries.map((entry) => {
				const ts = entry.timestamp
					? new Date(entry.timestamp).toLocaleTimeString('en-US',
						{ hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' })
					: null
				return (
					<div class={`log-entry log-entry--${entry.level || 'info'}`} data-id={entry.id}>
						{showTimestamp && ts && (
							<span class="entry-ts font-mono text-[10px] text-muted-foreground
								opacity-55 shrink-0 pt-0.5 min-w-[68px]" aria-hidden="true">{ts}</span>
						)}
						<span class="entry-icon shrink-0 mt-0.5 flex items-center" aria-hidden="true">
							{entry.level === 'success' && (
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
									stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<polyline points="20 6 9 17 4 12"/>
								</svg>
							)}
							{entry.level === 'error' && (
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
									stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="9"/>
									<line x1="12" y1="8" x2="12" y2="12"/>
									<line x1="12" y1="16" x2="12.01" y2="16"/>
								</svg>
							)}
							{entry.level === 'warning' && (
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
									stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-2.83 0z"/>
									<line x1="12" y1="9" x2="12" y2="13"/>
									<line x1="12" y1="17" x2="12.01" y2="17"/>
								</svg>
							)}
							{(entry.level === 'info' || entry.level === 'debug' || !entry.level) && (
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
									stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="9"/>
									<line x1="12" y1="8" x2="12" y2="12"/>
									<line x1="12" y1="16" x2="12.01" y2="16"/>
								</svg>
							)}
						</span>
						<div class="flex flex-col gap-0.5 min-w-0">
							<span class="text-[13px] text-foreground leading-relaxed">{entry.message}</span>
							{entry.details && (
								<span class="font-mono text-[11px] text-muted-foreground opacity-70">
									{entry.details}
								</span>
							)}
						</div>
					</div>
				)
			})
		)}
	</div>
</div>

<style>
	.log-container { max-height: var(--log-max-height, 320px); }

	.log-entry {
		display: flex;
		align-items: flex-start;
		gap: 9px;
		padding: 5px 14px;
		transition: background 0.1s ease;
	}
	.log-entry:hover { background: var(--secondary); }

	.log-entry--info .entry-icon { color: var(--blue); }
	.log-entry--success .entry-icon { color: var(--green); }
	.log-entry--warning .entry-icon { color: #eab308; }
	.log-entry--error .entry-icon { color: var(--red); }
	.log-entry--debug .entry-icon { color: var(--muted-foreground); opacity: 0.5; }

	.log-container::-webkit-scrollbar { width: 5px; }
	.log-container::-webkit-scrollbar-track { background: transparent; }
	.log-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
</style>
