---
interface WritingPost {
	slug: string
	title: string
	pubDate: string | Date
	conceptLabels?: string[]
}

interface Props {
	posts: WritingPost[]
	substackName?: string
	substackUrl?: string
}

const { posts = [], substackName = 'The Asymptotic', substackUrl = 'https://theasymptotic.substack.com/subscribe' } = Astro.props

const recentPosts = posts.slice(0, 10)
---

<section class="pane pane-writing" data-pane="writing" aria-label="Writing">
	<div class="writing-pane-header">
		<a href="/writing" class="writing-pane-header-link" data-modal-link data-route="/writing">
			<h2>Writing <span class="writing-sep">|</span> <strong>{substackName}</strong></h2>
		</a>
		<div class="pane-header-right">
			<a href={substackUrl} target="_blank" rel="noopener noreferrer" class="subscribe-btn">
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="11" height="11"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
				Subscribe
			</a>
		</div>
	</div>
	<div class="pane-body">
		{recentPosts.map((post) => (
			<a href={`/writing/${post.slug}`} class="writing-row" data-modal-link data-route="/writing" data-writing={post.slug}>
				<div class="writing-title">{post.title}</div>
				<div class="writing-meta">
					<span class="writing-date">{new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
					{post.conceptLabels?.map((label) => (
						<span class="writing-tag">{label}</span>
					))}
				</div>
			</a>
		))}
		{posts.length > 10 && (
			<div class="writing-see-all">
				<a href="/writing" class="see-all-link" data-modal-link>See all →</a>
			</div>
		)}
	</div>
</section>

<style>
	.writing-pane-header-link h2 {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.writing-pane-header-link h2 strong {
		color: var(--primary);
		font-weight: 700;
	}

	.writing-sep {
		color: var(--muted);
		font-weight: 400;
		margin: 0 2px;
	}

	.subscribe-btn {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 5px 11px;
		border-radius: 6px;
		border: 1px solid #c44e00;
		background: #c44e00;
		color: #fff;
		font-size: 11px;
		font-weight: 700;
		cursor: pointer;
		transition: background-color 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
		text-decoration: none;
		flex-shrink: 0;
	}

	.subscribe-btn:hover {
		background: #9e3d00;
		border-color: #9e3d00;
		text-decoration: none;
		color: #fff;
	}

	.writing-row {
		display: block;
		padding: 10px 14px;
		transition: opacity 0.2s ease, border-left-color 0.2s ease, background-color 0.15s ease;
		border-left: 3px solid transparent;
		text-decoration: none;
		touch-action: manipulation;
	}

	.writing-row:hover {
		background: var(--card-raised);
		text-decoration: none;
	}

	.writing-row:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: -2px;
	}

	.writing-row.highlighted {
		border-left-color: var(--primary);
	}

	.writing-row.dimmed {
		opacity: 0.25;
	}

	.writing-title {
		font-weight: 500;
		font-size: 14px;
		color: var(--foreground);
		line-height: 1.4;
	}

	.writing-meta {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-top: 3px;
		flex-wrap: wrap;
	}

	.writing-date,
	.writing-tag {
		font-family: var(--font-mono);
		font-size: 11px;
	}

	.writing-date {
		color: var(--muted);
	}

	.writing-tag {
		color: var(--primary);
		background: rgba(var(--primary-rgb), 0.08);
		padding: 1px 7px;
		border-radius: 999px;
	}

	.writing-see-all {
		padding: 10px 14px;
		text-align: center;
	}

	.see-all-link {
		font-size: 13px;
		color: var(--primary);
		text-decoration: none;
		font-weight: 500;
	}

	.see-all-link:hover {
		text-decoration: underline;
	}
</style>