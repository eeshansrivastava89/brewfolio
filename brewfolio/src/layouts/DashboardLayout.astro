---
import BaseHead from '../components/BaseHead.astro'
import ContentModal from '../components/ContentModal.astro'
import Footer from '../components/Footer.astro'
import HomeHeader from '../components/HomeHeader.astro'
import SearchOverlay from '../components/SearchOverlay.astro'
import ThemeProvider from '../components/ThemeProvider.astro'

interface Props {
	meta?: {
		title?: string
		description?: string
		ogImage?: string
		articleDate?: string
		canonicalUrl?: string
	}
	showFooter?: boolean
}

const { meta = {}, showFooter = true } = Astro.props
---

<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead
			title={meta.title}
			description={meta.description}
			ogImage={meta.ogImage}
			articleDate={meta.articleDate}
			canonicalUrl={meta.canonicalUrl}
		/>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<ThemeProvider />
		<div class="dashboard-shell">
			<HomeHeader />
			<main class="dashboard-main" id="main-content">
				<slot />
			</main>
			{showFooter && <Footer />}
		</div>
		<slot name="modal-source" />
		<SearchOverlay />
		<ContentModal />
		<slot name="search-data" />
	</body>
</html>

<style is:global>
	/* Tokens are imported by the consuming app's global CSS:
 * @import 'brewfolio/styles/tokens.css';
 * Ensure your app's global stylesheet imports tokens.css before any component styles. */

	html,
	body {
		min-height: 100%;
		margin: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		min-height: 100vh;
		font-family: var(--font-sans);
		font-weight: 400;
		background: var(--background);
		color: var(--foreground);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.color-scheme-dark {
		color-scheme: dark;
	}

	.skip-link {
		position: absolute;
		top: -100px;
		left: 0;
		background: var(--primary);
		color: var(--card);
		padding: 8px 16px;
		z-index: 999;
		font-size: 14px;
		text-decoration: none;
		border-radius: 0 0 4px 0;
	}

	.skip-link:focus {
		top: 0;
	}

	.dashboard-shell {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.dashboard-shell:has(.brewfolio-dashboard) {
		height: 100dvh;
		max-height: 100dvh;
	}

	.dashboard-main {
		flex: 1;
		min-height: 0;
		padding: 0 12px 12px;
	}

	@media (max-width: 768px) {
		.dashboard-main {
			padding: 0 12px 12px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
