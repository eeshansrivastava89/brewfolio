---
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ThemeProvider from '../components/ThemeProvider.astro'
import AppSections from '../components/AppSections.astro'
import type { SectionConfig, GitHubData } from '../lib/types'
import type { HeaderConfig } from '../lib/header'

interface Props {
	meta?: {
		title?: string
		description?: string
		ogImage?: string
		articleDate?: string
		canonicalUrl?: string
	}
	showFooter?: boolean
	siteName?: string
	header?: HeaderConfig
	headerNavItems?: { label: string; href: string }[]
	sections?: SectionConfig[]
	notebookEntries?: { id: string; title: string }[]
	githubData?: GitHubData | null
}

const {
	meta = {},
	showFooter = true,
	siteName,
	header,
	headerNavItems,
	sections,
	notebookEntries = [],
	githubData = null,
} = Astro.props

const headerSiteName = siteName ?? meta.title ?? 'Portfolio'
---

<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead
			title={meta.title}
			description={meta.description}
			ogImage={meta.ogImage}
			articleDate={meta.articleDate}
			canonicalUrl={meta.canonicalUrl}
		/>
	</head>
	<body>
		<a href="#main-content" class="brewfolio-skip-link">Skip to content</a>
		<ThemeProvider />
		<div class="brewfolio-app-shell">
			<Header
				navItems={headerNavItems}
				siteName={header?.siteName ?? headerSiteName}
				showSearch={false}
				showClockWeather={header?.showClockWeather}
				latitude={header?.latitude}
				longitude={header?.longitude}
				timezone={header?.timezone}
				cityName={header?.cityName}
			/>
			<main class="brewfolio-app-main" id="main-content">
				{sections !== undefined && sections.length > 0 ? (
					<AppSections
						sections={sections}
						notebookEntries={notebookEntries}
						githubData={githubData}
					/>
				) : sections !== undefined && sections.length === 0 ? (
					<div class="flex flex-col gap-4 text-sm text-muted-foreground p-6">
						<p>No sections configured yet.</p>
						<p>Add section blocks in <strong>Keystatic → Sections → Sections</strong>.</p>
					</div>
				) : (
					<slot />
				)}
			</main>
			{showFooter && <Footer />}
		</div>
	</body>
</html>

<style is:global>
	html,
	body {
		min-height: 100%;
		margin: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		min-height: 100vh;
		font-family: var(--font-sans);
		font-weight: 400;
		background: var(--background);
		color: var(--foreground);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.color-scheme-dark {
		color-scheme: dark;
	}

	.brewfolio-skip-link {
		position: absolute;
		top: -100px;
		left: 0;
		background: var(--primary);
		color: var(--card);
		padding: 8px 16px;
		z-index: 999;
		font-size: 14px;
		text-decoration: none;
		border-radius: 0 0 4px 0;
	}

	.brewfolio-skip-link:focus {
		top: 0;
	}

	.brewfolio-app-shell {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.brewfolio-app-main {
		flex: 1;
		min-height: 0;
		padding: 0 12px 12px;
	}

	@media (max-width: 768px) {
		.brewfolio-app-main {
			padding: 0 12px 12px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
